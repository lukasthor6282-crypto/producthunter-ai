      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  * { box-sizing: border-box; }\n\n  .ph-root {\n    font-family: 'Inter', sans-serif;\n    background: #07090d;\n    color: #f8fafc;\n    overflow-x: hidden;\n  }\n\n  /* Orbs */\n  @keyframes orbFloat1 {\n    0%, 100% { transform: translate(0, 0) scale(1); }\n    33% { transform: translate(40px, -60px) scale(1.08); }\n    66% { transform: translate(-30px, 30px) scale(0.95); }\n  }\n  @keyframes orbFloat2 {\n    0%, 100% { transform: translate(0, 0) scale(1); }\n    40% { transform: translate(-50px, 40px) scale(1.1); }\n    70% { transform: translate(30px, -40px) scale(0.92); }\n  }\n  @keyframes orbFloat3 {\n    0%, 100% { transform: translate(0, 0) scale(1); }\n    50% { transform: translate(60px, 50px) scale(1.05); }\n  }\n  @keyframes mockupFloat {\n    0%, 100% { transform: translateY(0px); }\n    50% { transform: translateY(-12px); }\n  }\n  @keyframes shimmer {\n    0% { background-position: -200% center; }\n    100% { background-position: 200% center; }\n  }\n  @keyframes scoreRing {\n    from { stroke-dashoffset: 251; }\n    to { stroke-dashoffset: 32; }\n  }\n  @keyframes pulse {\n    0%, 100% { opacity: 1; }\n    50% { opacity: 0.4; }\n  }\n  @keyframes gradientShift {\n    0%, 100% { background-position: 0% 50%; }\n    50% { background-position: 100% 50%; }\n  }\n\n  .orb {\n    position: absolute;\n    border-radius: 50%;\n    filter: blur(80px);\n    pointer-events: none;\n  }\n\n  .glass {\n    background: rgba(255,255,255,0.06);\n    border: 1px solid rgba(255,255,255,0.12);\n    backdrop-filter: blur(20px);\n    -webkit-backdrop-filter: blur(20px);\n  }\n\n  .glass-strong {\n    background: rgba(255,255,255,0.09);\n    border: 1px solid rgba(255,255,255,0.16);\n    backdrop-filter: blur(24px);\n    -webkit-backdrop-filter: blur(24px);\n  }\n\n  .electric-glow {\n    box-shadow: 0 0 20px rgba(98,230,255,0.3), 0 0 60px rgba(98,230,255,0.1), inset 0 1px 0 rgba(98,230,255,0.2);\n  }\n\n  .electric-glow-btn {\n    box-shadow: 0 0 24px rgba(98,230,255,0.4), 0 4px 16px rgba(98,230,255,0.2);\n    transition: all 0.3s ease;\n  }\n  .electric-glow-btn:hover {\n    box-shadow: 0 0 36px rgba(98,230,255,0.6), 0 6px 24px rgba(98,230,255,0.3);\n    transform: translateY(-2px);\n  }\n\n  .text-gradient {\n    background: linear-gradient(135deg, #62e6ff, #65f0b7);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n    background-clip: text;\n  }\n\n  .dot-grid {\n    background-image: radial-gradient(circle, rgba(255,255,255,0.12) 1px, transparent 1px);\n    background-size: 32px 32px;\n  }\n\n  .mockup-float {\n    animation: mockupFloat 6s ease-in-out infinite;\n  }\n\n  .score-ring-anim {\n    animation: scoreRing 2s ease-out forwards;\n  }\n\n  .shimmer-text {\n    background: linear-gradient(90deg, #62e6ff, #65f0b7, #62e6ff);\n    background-size: 200% auto;\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n    background-clip: text;\n    animation: shimmer 3s linear infinite;\n  }\n\n  .nav-link {\n    color: #94a3b8;\n    font-size: 14px;\n    font-weight: 500;\n    transition: color 0.2s;\n    cursor: pointer;\n  }\n  .nav-link:hover { color: #f8fafc; }\n\n  .section-label {\n    font-size: 11px;\n    font-weight: 600;\n    letter-spacing: 0.15em;\n    text-transform: uppercase;\n    color: #62e6ff;\n  }\n\n  .bento-card {\n    background: rgba(255,255,255,0.05);\n    border: 1px solid rgba(255,255,255,0.1);\n    border-radius: 20px;\n    padding: 28px;\n    transition: border-color 0.3s, background 0.3s;\n    position: relative;\n    overflow: hidden;\n  }\n  .bento-card:hover {\n    border-color: rgba(98,230,255,0.3);\n    background: rgba(255,255,255,0.07);\n  }\n  .bento-card::before {\n    content: '';\n    position: absolute;\n    inset: 0;\n    background: linear-gradient(135deg, rgba(98,230,255,0.03), transparent 60%);\n    pointer-events: none;\n  }\n\n  .product-row {\n    display: flex;\n    align-items: center;\n    gap: 16px;\n    padding: 16px 20px;\n    background: rgba(255,255,255,0.04);\n    border: 1px solid rgba(255,255,255,0.08);\n    border-radius: 14px;\n    transition: all 0.2s;\n  }\n  .product-row:hover {\n    background: rgba(255,255,255,0.07);\n    border-color: rgba(98,230,255,0.2);\n  }\n\n  .badge {\n    padding: 4px 12px;\n    border-radius: 100px;\n    font-size: 11px;\n    font-weight: 600;\n    letter-spacing: 0.03em;\n  }\n\n  .badge-mint { background: rgba(101,240,183,0.15); color: #65f0b7; border: 1px solid rgba(101,240,183,0.3); }\n  .badge-electric { background: rgba(98,230,255,0.12); color: #62e6ff; border: 1px solid rgba(98,230,255,0.25); }\n  .badge-ember { background: rgba(248,184,92,0.12); color: #f8b85c; border: 1px solid rgba(248,184,92,0.25); }\n  .badge-violet { background: rgba(139,92,246,0.12); color: #a78bfa; border: 1px solid rgba(139,92,246,0.25); }\n\n  .stat-number {\n    font-size: 48px;\n    font-weight: 800;\n    letter-spacing: -0.03em;\n    line-height: 1;\n  }\n\n  .mini-bar {\n    height: 6px;\n    border-radius: 100px;\n    transition: width 0.6s ease;\n  }\n</style>\n\n<div class=\"ph-root\" data-kid=\"1\">\n\n  \n  <nav style=\"position: relative; z-index: 50; border-bottom: 1px solid rgba(255,255,255,0.08);\" class=\"glass\" data-kid=\"2\">\n    <div style=\"max-width: 1280px; margin: 0 auto; padding: 0 40px; height: 68px; display: flex; align-items: center; justify-content: space-between;\" data-kid=\"3\">\n      \n      <div style=\"display: flex; align-items: center; gap: 10px;\" data-kid=\"4\">\n        <div style=\"width: 36px; height: 36px; background: linear-gradient(135deg, #62e6ff, #65f0b7); border-radius: 10px; display: flex; align-items: center; justify-content: center;\" data-kid=\"5\">\n          <span style=\"font-size: 15px; font-weight: 900; color: #07090d; letter-spacing: -0.05em;\" data-kid=\"6\">PH</span>\n        </div>\n        <span style=\"font-size: 15px; font-weight: 700; color: #f8fafc; letter-spacing: -0.02em;\" data-kid=\"7\">ProductHunter <span style=\"color: #62e6ff;\" data-kid=\"8\">AI</span></span>\n      </div>\n      \n      <div style=\"display: flex; align-items: center; gap: 36px;\" data-kid=\"9\">\n        <a class=\"nav-link\" data-kid=\"10\">Como funciona</a>\n        <a class=\"nav-link\" data-kid=\"11\">Benefícios</a>\n        <a class=\"nav-link\" data-kid=\"12\">Demonstração</a>\n        <a class=\"nav-link\" data-kid=\"13\">Preços</a>\n      </div>\n      \n      <button class=\"electric-glow-btn\" style=\"padding: 10px 22px; background: linear-gradient(135deg, rgba(98,230,255,0.15), rgba(98,230,255,0.25)); border: 1px solid rgba(98,230,255,0.5); border-radius: 10px; color: #62e6ff; font-size: 14px; font-weight: 600; font-family: 'Inter', sans-serif; cursor: pointer; display: flex; align-items: center; gap: 7px;\" data-kid=\"14\">\n        <i class=\"ti ti-sparkles\" style=\"font-size: 15px;\" data-kid=\"15\"></i>\n        Começar grátis\n      </button>\n    </div>\n  </nav>\n\n  \n  <section style=\"position: relative; min-height: 960px; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 80px 40px 60px; overflow: hidden;\" data-kid=\"16\">\n    \n    <div class=\"orb\" style=\"width: 600px; height: 600px; background: rgba(98,230,255,0.12); top: -100px; left: -150px; animation: orbFloat1 14s ease-in-out infinite;\" data-kid=\"17\"></div>\n    <div class=\"orb\" style=\"width: 500px; height: 500px; background: rgba(139,92,246,0.1); top: 100px; right: -100px; animation: orbFloat2 18s ease-in-out infinite;\" data-kid=\"18\"></div>\n    <div class=\"orb\" style=\"width: 400px; height: 400px; background: rgba(101,240,183,0.08); bottom: 0; left: 30%; animation: orbFloat3 12s ease-in-out infinite;\" data-kid=\"19\"></div>\n    \n    <div class=\"dot-grid\" style=\"position: absolute; inset: 0; opacity: 0.35;\" data-kid=\"20\"></div>\n    \n    <div style=\"position: absolute; inset: 0; background: radial-gradient(ellipse 80% 60% at 50% 40%, transparent 30%, #07090d 80%);\" data-kid=\"21\"></div>\n\n    \n    <div style=\"position: relative; z-index: 10; display: flex; flex-direction: column; align-items: center; text-align: center; max-width: 900px;\" data-kid=\"22\">\n      \n      <div class=\"glass\" style=\"display: inline-flex; align-items: center; gap: 8px; padding: 7px 18px; border-radius: 100px; margin-bottom: 32px; border-color: rgba(98,230,255,0.25);\" data-kid=\"23\">\n        <span style=\"color: #62e6ff; font-size: 12px;\" data-kid=\"24\">✦</span>\n        <span style=\"font-size: 13px; font-weight: 500; color: #62e6ff; letter-spacing: 0.02em;\" data-kid=\"25\">Inteligência de Mercado para Vendedores</span>\n      </div>\n      \n      <h1 style=\"font-size: 72px; font-weight: 800; line-height: 1.05; letter-spacing: -0.04em; margin: 0 0 28px; color: #f8fafc;\" data-kid=\"26\">\n        A IA que encontra os<br data-kid=\"27\">melhores produtos para o<br data-kid=\"28\">seu perfil de <span class=\"text-gradient\" data-kid=\"29\">venda.</span>\n      </h1>\n      \n      <p style=\"font-size: 19px; line-height: 1.65; color: #94a3b8; max-width: 620px; margin: 0 0 44px; font-weight: 400;\" data-kid=\"30\">\n        Informe onde você vende, seu nicho e objetivo. O ProductHunter AI recomenda produtos com maior chance de lucro, conversão e oportunidade.\n      </p>\n      \n      <div style=\"display: flex; align-items: center; gap: 16px; margin-bottom: 64px;\" data-kid=\"31\">\n        <button class=\"electric-glow-btn\" style=\"padding: 14px 28px; background: linear-gradient(135deg, rgba(98,230,255,0.2), rgba(98,230,255,0.35)); border: 1px solid rgba(98,230,255,0.6); border-radius: 12px; color: #62e6ff; font-size: 15px; font-weight: 600; font-family: 'Inter', sans-serif; cursor: pointer; display: flex; align-items: center; gap: 9px; letter-spacing: -0.01em;\" data-kid=\"32\">\n          <i class=\"ti ti-sparkles\" style=\"font-size: 18px;\" data-kid=\"33\"></i>\n          Encontrar produtos\n        </button>\n        <button style=\"padding: 14px 28px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.14); border-radius: 12px; color: #f8fafc; font-size: 15px; font-weight: 500; font-family: 'Inter', sans-serif; cursor: pointer; display: flex; align-items: center; gap: 9px; transition: all 0.2s; letter-spacing: -0.01em;\" onmouseover=\"this.style.background='rgba(255,255,255,0.1)'\" onmouseout=\"this.style.background='rgba(255,255,255,0.06)'\" data-kid=\"34\">\n          <i class=\"ti ti-player-play\" style=\"font-size: 16px; color: #94a3b8;\" data-kid=\"35\"></i>\n          Ver demonstração\n        </button>\n      </div>\n\n      \n      <div class=\"mockup-float\" style=\"width: 100%; max-width: 980px;\" data-kid=\"36\">\n        <div class=\"electric-glow glass-strong\" style=\"border-radius: 20px; overflow: hidden; border: 1px solid rgba(98,230,255,0.2);\" data-kid=\"37\">\n          \n          <div style=\"padding: 14px 20px; border-bottom: 1px solid rgba(255,255,255,0.08); display: flex; align-items: center; gap: 8px; background: rgba(0,0,0,0.2);\" data-kid=\"38\">\n            <div style=\"width: 12px; height: 12px; border-radius: 50%; background: rgba(255,255,255,0.15);\" data-kid=\"39\"></div>\n            <div style=\"width: 12px; height: 12px; border-radius: 50%; background: rgba(255,255,255,0.1);\" data-kid=\"40\"></div>\n            <div style=\"width: 12px; height: 12px; border-radius: 50%; background: rgba(255,255,255,0.08);\" data-kid=\"41\"></div>\n            <div style=\"flex: 1; height: 6px; background: rgba(255,255,255,0.06); border-radius: 100px; margin: 0 16px;\" data-kid=\"42\"></div>\n            <span style=\"font-size: 11px; color: rgba(255,255,255,0.3); font-weight: 500;\" data-kid=\"43\">ProductHunter AI</span>\n          </div>\n          \n          <div style=\"display: flex; height: 440px;\" data-kid=\"44\">\n            \n            <div style=\"width: 60px; border-right: 1px solid rgba(255,255,255,0.07); display: flex; flex-direction: column; align-items: center; padding: 20px 0; gap: 20px; background: rgba(0,0,0,0.15);\" data-kid=\"45\">\n              <div style=\"width: 32px; height: 32px; background: linear-gradient(135deg, #62e6ff, #65f0b7); border-radius: 8px; display: flex; align-items: center; justify-content: center;\" data-kid=\"46\">\n                <span style=\"font-size: 11px; font-weight: 900; color: #07090d;\" data-kid=\"47\">PH</span>\n              </div>\n              <i class=\"ti ti-layout-dashboard\" style=\"color: #62e6ff; font-size: 18px;\" data-kid=\"48\"></i>\n              <i class=\"ti ti-sparkles\" style=\"color: rgba(255,255,255,0.3); font-size: 18px;\" data-kid=\"49\"></i>\n              <i class=\"ti ti-chart-bar\" style=\"color: rgba(255,255,255,0.3); font-size: 18px;\" data-kid=\"50\"></i>\n              <i class=\"ti ti-flask\" style=\"color: rgba(255,255,255,0.3); font-size: 18px;\" data-kid=\"51\"></i>\n            </div>\n            \n            <div style=\"flex: 1; padding: 24px; display: flex; flex-direction: column; gap: 20px; overflow: hidden;\" data-kid=\"52\">\n              \n              <div style=\"display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px;\" data-kid=\"53\">\n                <div style=\"background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.09); border-radius: 12px; padding: 16px;\" data-kid=\"54\">\n                  <div style=\"font-size: 10px; color: #94a3b8; font-weight: 500; margin-bottom: 8px; letter-spacing: 0.05em; text-transform: uppercase;\" data-kid=\"55\">Oportunidades</div>\n                  <div style=\"font-size: 26px; font-weight: 800; color: #f8fafc; letter-spacing: -0.03em;\" data-kid=\"56\">1,204