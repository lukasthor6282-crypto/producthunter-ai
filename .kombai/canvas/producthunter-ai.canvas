      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n</style>\n<script src=\"https://cdn.jsdelivr.net/npm/chart.js\" data-kid=\"1\"></script>\n\n<div style=\"font-family: 'Inter', sans-serif; background: #07090d; min-height: 900px; display: flex; position: relative; overflow: hidden;\" data-kid=\"2\">\n\n  \n  <div style=\"position: absolute; inset: 0; pointer-events: none; z-index: 0;\" data-kid=\"3\">\n    <div style=\"position: absolute; top: -200px; left: -100px; width: 600px; height: 600px; border-radius: 50%; background: radial-gradient(circle, rgba(98,230,255,0.06) 0%, transparent 70%);\" data-kid=\"4\"></div>\n    <div style=\"position: absolute; top: 100px; right: -150px; width: 500px; height: 500px; border-radius: 50%; background: radial-gradient(circle, rgba(139,92,246,0.05) 0%, transparent 70%);\" data-kid=\"5\"></div>\n    <div style=\"position: absolute; bottom: -100px; left: 30%; width: 700px; height: 400px; border-radius: 50%; background: radial-gradient(circle, rgba(101,240,183,0.04) 0%, transparent 70%);\" data-kid=\"6\"></div>\n    \n    <div style=\"position: absolute; inset: 0; background-image: linear-gradient(rgba(255,255,255,0.015) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.015) 1px, transparent 1px); background-size: 48px 48px;\" data-kid=\"7\"></div>\n  </div>\n\n  \n  <div style=\"width: 256px; min-height: 900px; flex-shrink: 0; background: rgba(255,255,255,0.04); border-right: 1px solid rgba(255,255,255,0.10); display: flex; flex-direction: column; position: relative; z-index: 10; backdrop-filter: blur(24px);\" data-kid=\"8\">\n    \n    \n    <div style=\"padding: 24px 20px 20px; border-bottom: 1px solid rgba(255,255,255,0.08);\" data-kid=\"9\">\n      <div style=\"display: flex; align-items: center; gap: 12px;\" data-kid=\"10\">\n        <div style=\"width: 38px; height: 38px; border-radius: 10px; background: linear-gradient(135deg, #62e6ff, #3b82f6); display: flex; align-items: center; justify-content: center; font-size: 14px; font-weight: 800; color: #07090d; flex-shrink: 0; box-shadow: 0 0 20px rgba(98,230,255,0.3);\" data-kid=\"11\">PH</div>\n        <div data-kid=\"12\">\n          <div style=\"font-size: 13px; font-weight: 700; color: #f8fafc; letter-spacing: -0.02em;\" data-kid=\"13\">ProductHunter</div>\n          <div style=\"font-size: 11px; color: #62e6ff; font-weight: 500; letter-spacing: 0.02em;\" data-kid=\"14\">AI</div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div style=\"padding: 20px 20px 8px;\" data-kid=\"15\">\n      <span style=\"font-size: 10px; font-weight: 600; color: #475569; letter-spacing: 0.1em; text-transform: uppercase;\" data-kid=\"16\">Navegação</span>\n    </div>\n\n    \n    <nav style=\"padding: 0 12px; flex: 1; display: flex; flex-direction: column; gap: 2px;\" data-kid=\"17\">\n      \n      <div style=\"display: flex; align-items: center; gap: 10px; padding: 10px 12px; border-radius: 8px; background: rgba(98,230,255,0.10); border: 1px solid rgba(98,230,255,0.20); cursor: pointer; position: relative;\" data-kid=\"18\">\n        <div style=\"position: absolute; left: 0; top: 50%; transform: translateY(-50%); width: 3px; height: 20px; background: #62e6ff; border-radius: 0 2px 2px 0;\" data-kid=\"19\"></div>\n        <i class=\"ti ti-layout-dashboard\" style=\"font-size: 17px; color: #62e6ff;\" data-kid=\"20\"></i>\n        <span style=\"font-size: 13px; font-weight: 600; color: #62e6ff;\" data-kid=\"21\">Dashboard</span>\n      </div>\n\n      <div style=\"display: flex; align-items: center; gap: 10px; padding: 10px 12px; border-radius: 8px; cursor: pointer;\" data-kid=\"22\">\n        <i class=\"ti ti-sparkles\" style=\"font-size: 17px; color: #64748b;\" data-kid=\"23\"></i>\n        <span style=\"font-size: 13px; font-weight: 500; color: #94a3b8;\" data-kid=\"24\">Recomendar</span>\n      </div>\n\n      <div style=\"display: flex; align-items: center; gap: 10px; padding: 10px 12px; border-radius: 8px; cursor: pointer;\" data-kid=\"25\">\n        <i class=\"ti ti-trophy\" style=\"font-size: 17px; color: #64748b;\" data-kid=\"26\"></i>\n        <span style=\"font-size: 13px; font-weight: 500; color: #94a3b8;\" data-kid=\"27\">Resultados</span>\n      </div>\n\n      <div style=\"display: flex; align-items: center; gap: 10px; padding: 10px 12px; border-radius: 8px; cursor: pointer;\" data-kid=\"28\">\n        <i class=\"ti ti-chart-bar\" style=\"font-size: 17px; color: #64748b;\" data-kid=\"29\"></i>\n        <span style=\"font-size: 13px; font-weight: 500; color: #94a3b8;\" data-kid=\"30\">Simulador</span>\n      </div>\n\n      <div style=\"display: flex; align-items: center; gap: 10px; padding: 10px 12px; border-radius: 8px; cursor: pointer;\" data-kid=\"31\">\n        <i class=\"ti ti-flask\" style=\"font-size: 17px; color: #64748b;\" data-kid=\"32\"></i>\n        <span style=\"font-size: 13px; font-weight: 500; color: #94a3b8;\" data-kid=\"33\">Lab de IA</span>\n      </div>\n\n      <div style=\"display: flex; align-items: center; gap: 10px; padding: 10px 12px; border-radius: 8px; cursor: pointer;\" data-kid=\"34\">\n        <i class=\"ti ti-heart\" style=\"font-size: 17px; color: #64748b;\" data-kid=\"35\"></i>\n        <span style=\"font-size: 13px; font-weight: 500; color: #94a3b8;\" data-kid=\"36\">Favoritos</span>\n      </div>\n    </nav>\n\n    \n    <div style=\"padding: 16px; border-top: 1px solid rgba(255,255,255,0.08); display: flex; align-items: center; gap: 10px;\" data-kid=\"37\">\n      <img src=\"https://i.pravatar.cc/40?u=user1\" alt=\"avatar\" width=\"34\" height=\"34\" style=\"border-radius: 50%; border: 2px solid rgba(98,230,255,0.3);\" decoding=\"async\" loading=\"lazy\" data-kid=\"38\">\n      <div style=\"flex: 1; min-width: 0;\" data-kid=\"39\">\n        <div style=\"font-size: 12px; font-weight: 600; color: #f8fafc; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;\" data-kid=\"40\">Lucas Vendedor</div>\n        <div style=\"display: inline-flex; align-items: center; gap: 4px; margin-top: 2px; background: rgba(98,230,255,0.12); border: 1px solid rgba(98,230,255,0.25); border-radius: 4px; padding: 1px 6px;\" data-kid=\"41\">\n          <div style=\"width: 5px; height: 5px; background: #62e6ff; border-radius: 50%;\" data-kid=\"42\"></div>\n          <span style=\"font-size: 10px; font-weight: 600; color: #62e6ff; letter-spacing: 0.04em;\" data-kid=\"43\">Pro Plan</span>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  \n  <div style=\"flex: 1; display: flex; flex-direction: column; min-width: 0; position: relative; z-index: 5;\" data-kid=\"44\">\n\n    \n    <div style=\"padding: 20px 32px; border-bottom: 1px solid rgba(255,255,255,0.08); display: flex; align-items: center; justify-content: space-between; background: rgba(7,9,13,0.7); backdrop-filter: blur(12px);\" data-kid=\"45\">\n      <div data-kid=\"46\">\n        <div style=\"display: flex; align-items: center; gap: 8px;\" data-kid=\"47\">\n          <span style=\"font-size: 12px; color: #475569;\" data-kid=\"48\">ProductHunter AI</span>\n          <span style=\"color: #334155; font-size: 12px;\" data-kid=\"49\">/</span>\n          <span style=\"font-size: 12px; font-weight: 600; color: #f8fafc;\" data-kid=\"50\">Dashboard</span>\n        </div>\n        <div style=\"font-size: 22px; font-weight: 800; color: #f8fafc; letter-spacing: -0.03em; margin-top: 2px;\" data-kid=\"51\">Visão Geral do Mercado</div>\n      </div>\n      <div style=\"display: flex; align-items: center; gap: 16px;\" data-kid=\"52\">\n        <div style=\"font-size: 12px; color: #64748b;\" data-kid=\"53\">Sáb, 31 Mai 2025</div>\n        <div style=\"width: 36px; height: 36px; border-radius: 8px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); display: flex; align-items: center; justify-content: center; cursor: pointer; position: relative;\" data-kid=\"54\">\n          <i class=\"ti ti-bell\" style=\"font-size: 16px; color: #94a3b8;\" data-kid=\"55\"></i>\n          <div style=\"position: absolute; top: 7px; right: 7px; width: 7px; height: 7px; background: #f8b85c; border-radius: 50%; border: 1.5px solid #07090d;\" data-kid=\"56\"></div>\n        </div>\n        <button style=\"display: flex; align-items: center; gap: 8px; padding: 9px 18px; border-radius: 8px; background: linear-gradient(135deg, rgba(98,230,255,0.20), rgba(98,230,255,0.08)); border: 1px solid rgba(98,230,255,0.35); color: #62e6ff; font-size: 13px; font-weight: 600; cursor: pointer; font-family: 'Inter', sans-serif; box-shadow: 0 0 16px rgba(98,230,255,0.15);\" data-kid=\"57\">\n          <i class=\"ti ti-sparkles\" style=\"font-size: 14px;\" data-kid=\"58\"></i>\n          Nova Análise\n        </button>\n      </div>\n    </div>\n\n    \n    <div style=\"flex: 1; padding: 28px 32px; overflow-y: auto;\" data-kid=\"59\">\n\n      \n      <div style=\"display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px;\" data-kid=\"60\">\n\n        \n        <div style=\"background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.12); border-radius: 14px; padding: 20px; backdrop-filter: blur(16px); position: relative; overflow: hidden;\" data-kid=\"61\">\n          <div style=\"position: absolute; top: 0; right: 0; width: 80px; height: 80px; background: radial-gradient(circle, rgba(98,230,255,0.08), transparent); border-radius: 50%;\" data-kid=\"62\"></div>\n          <div style=\"display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px;\" data-kid=\"63\">\n            <div style=\"width: 36px; height: 36px; background: rgba(98,230,255,0.12); border: 1px solid rgba(98,230,255,0.25); border-radius: 9px; display: flex; align-items: center; justify-content: center;\" data-kid=\"64\">\n              <i class=\"ti ti-bolt\" style=\"font-size: 18px; color: #62e6ff;\" data-kid=\"65\"></i>\n            </div>\n            <span style=\"font-size: 11px; color: #22c55e; font-weight: 600; background: rgba(34,197,94,0.12); padding: 3px 8px; border-radius: 20px;\" data-kid=\"66\">↑ 12%</span>\n          </div>\n          <div style=\"font-size: 34px; font-weight: 800; color: #f8fafc; letter-spacing: -0.03em; line-height: 1;\" data-kid=\"67\">1,204</div>\n          <div style=\"font-size: 12px; color: #64748b; margin-top: 4px; font-weight: 500;\" data-kid=\"68\">Oportunidades</div>\n          <div style=\"font-size: 11px; color: #94a3b8; margin-top: 2px;\" data-kid=\"69\">esta semana</div>\n        </div>\n\n        \n        <div style=\"background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.12); border-radius: 14px; padding: 20px; backdrop-filter: blur(16px); display: flex; align-items: center; gap: 16px;\" data-kid=\"70\">\n          <div style=\"flex-shrink: 0;\" data-kid=\"71\">\n            <svg width=\"62\" height=\"62\" viewBox=\"0 0 62 62\" data-kid=\"72\">\n              <circle cx=\"31\" cy=\"31\" r=\"26\" fill=\"none\" stroke=\"rgba(255,255,255,0.08)\" stroke-width=\"5\" data-kid=\"73\"></circle>\n              <circle cx=\"31\" cy=\"31\" r=\"26\" fill=\"none\" stroke=\"#62e6ff\" stroke-width=\"5\" stroke-linecap=\"round\" stroke-dasharray=\"163.4\" stroke-dashoffset=\"27\" transform=\"rotate(-90 31 31)\" style=\"filter: drop-shadow(0 0 6px #62e6ff);\" data-kid=\"74\"></circle>\n              <text x=\"31\" y=\"36\" text-anchor=\"middle\" fill=\"#f8fafc\" font-size=\"13\" font-weight=\"800\" font-family=\"Inter\" data-kid=\"75\">84</text>\n            </svg>\n          </div>\n          <div data-kid=\"76\">\n            <div style=\"font-size: 11px; color: #62e6ff; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; margin-bottom: 4px;\" data-kid=\"77\">Score Médio</div>\n            <div style=\"font-size: 22px; font-weight: 800; color: #f8fafc; letter-spacing: -0.02em;\" data-kid=\"78\">84/100</div>\n            <div style=\"font-size: 12px; color: #64748b; margin-top: 2px;\" data-kid=\"79\">Mercado global</div>\n          </div>\n        </div>\n\n        \n        <div style=\"background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.12); border-radius: 14px; padding: 20px; backdrop-filter: blur(16px); position: relative; overflow: hidden;\" data-kid=\"80\">\n          <div style=\"position: absolute; top: 0; right: 0; width: 80px; height: 80px; background: radial-gradient(circle, rgba(101,240,183,0.07), transparent); border-radius: 50%;\" data-kid=\"81\"></div>\n          <div style=\"display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px;\" data-kid=\"82\">\n            <div style=\"width: 36px; height: 36px; background: rgba(101,240,183,0.12); border: 1px solid rgba(101,240,183,0.25); border-radius: 9px; display: flex; align-items: center; justify-content: center;\" data-kid=\"83\">\n              <i class=\"ti ti-trending-up\" style=\"font-size: 18px; color: #65f0b7;\" data-kid=\"84\"></i>\n            </div>\n            <span style=\"font-size: 11px; background: rgba(101,240,183,0.15); color: #65f0b7; font-weight: 600; padding: 3px 8px; border-radius: 20px;\" data-kid=\"85\">Tecnologia</span>\n          </div>\n          <div style=\"font-size: 34px; font-weight: 800; color: #f8fafc; letter-spacing: -0.03em; line-height: 1;\" data-kid=\"86\">42.5%</div>\n          <div style=\"font-size: 12px; color: #64748b; margin-top: 4px; font-weight: 500;\" data-kid=\"87\">Melhor Margem Média</div>\n          <div style=\"font-size: 11px; color: #94a3b8; margin-top: 2px;\" data-kid=\"88\">nicho destaque</div>\n        </div>\n\n        \n        <div style=\"background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.12); border-radius: 14px; padding: 20px; backdrop-filter: blur(16px);\" data-kid=\"89\">\n          <div style=\"display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px;\" data-kid=\"90\">\n            <div style=\"display: flex; align-items: center; gap: 8px;\" data-kid=\"91\">\n              <div style=\"width: 9px; height: 9px; background: #65f0b7; border-radius: 50%; box-shadow: 0 0 8px #65f0b7; animation: pulse 2s infinite;\" data-kid=\"92\"></div>\n              <span style=\"font-size: 11px; color: #65f0b7; font-weight: 600;\" data-kid=\"93\">Ao vivo</span>\n            </div>\n          </div>\n          <div style=\"font-size: 34px; font-weight: 800; color: #f8fafc; letter-spacing: -0.03em; line-height: 1;\" data-kid=\"94\">3 Ativos</div>\n          <div style=\"font-size: 12px; color: #64748b; margin-top: 4px; font-weight: 500;\" data-kid=\"95\">Nichos em Análise</div>\n          <div style=\"display: flex; align-items: center; gap: 8px; margin-top: 12px;\" data-kid=\"96\">\n            <div style=\"width: 24px; height: 24px; border-radius: 6px; background: rgba(255,198,0,0.15); border: 1px solid rgba(255,198,0,0.3); display: flex; align-items: center; justify-content: center;\" data-kid=\"97\">\n              <i class=\"ti ti-shopping-bag\" style=\"font-size: 12px; color: #ffc600;\" data-kid=\"98\"></i>\n            </div>\n            <div style=\"width: 24px; height: 24px; border-radius: 6px; background: rgba(255,153,0,0.15); border: 1px solid rgba(255,153,0,0.3); display: flex; align-items: center; justify-content: center;\" data-kid=\"99\">\n              <i class=\"ti ti-shopping-cart\" style=\"font-size: 12px; color: #ff9900;\" data-kid=\"100\"></i>\n            </div>\n            <div style=\"width: 24px; height: 24px; border-radius: 6px; background: rgba(255,90,0,0.15); border: 1px solid rgba(255,90,0,0.3); display: flex; align-items: center; justify-content: center;\" data-kid=\"101\">\n              <i class=\"ti ti-box\" style=\"font-size: 12px; color: #ee4d2d;\" data-kid=\"102\"></i>\n            </div>\n            <span style=\"font-size: 11px; color: #64748b;\" data-kid=\"103\">ML · Amazon · Shopee</span>\n          </div>\n        </div>\n      </div>\n\n      \n      <div style=\"display: grid; grid-template-columns: repeat(12, 1fr); gap: 16px;\" data-kid=\"104\">\n\n        \n        <div style=\"grid-column: span 8; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.10); border-radius: 14px; padding: 20px; backdrop-filter: blur(16px);\" data-kid=\"105\">\n          <div style=\"display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px;\" data-kid=\"106\">\n            <div data-kid=\"107\">\n              <div style=\"font-size: 14px; font-weight: 700; color: #f8fafc;\" data-kid=\"108\">Tendência por Nicho</div>\n              <div style=\"font-size: 12px; color: #64748b; margin-top: 2px;\" data-kid=\"109\">Evolução semanal dos principais nichos</div>\n            </div>\n            <select style=\"background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.14); border-radius: 7px; color: #94a3b8; font-size: 12px; padding: 6px 10px; font-family: 'Inter', sans-serif; cursor: pointer; outline: none;\" data-kid=\"110\">\n              <option data-kid=\"111\">30 dias</option>\n              <option data-kid=\"112\">7 dias</option>\n              <option data-kid=\"113\">90 dias</option>\n            </select>\n          </div>\n          <canvas id=\"trendChart\" height=\"220\" data-kid=\"114\"></canvas>\n        </div>\n\n        \n        <div style=\"grid-column: span 4; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.10); border-radius: 14px; padding: 20px; backdrop-filter: blur(16px);\" data-kid=\"115\">\n          <div style=\"margin-bottom: 16px;\" data-kid=\"116\">\n            <div style=\"font-size: 14px; font-weight: 700; color: #f8fafc;\" data-kid=\"117\">Comparação Marketplaces</div>\n            <div style=\"font-size: 12px; color: #64748b; margin-top: 2px;\" data-kid=\"1