      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n</style>\n\n<div class=\"flex min-h-[1100px] font-['Inter',sans-serif] text-[#f8fafc]\" style=\"background:#07090d;\" data-kid=\"1\">\n\n  \n  <aside class=\"w-16 shrink-0 flex flex-col items-center py-6 gap-6 border-r border-white/[0.08]\" style=\"background:rgba(255,255,255,0.03);\" data-kid=\"2\">\n    <div class=\"w-8 h-8 rounded-sm flex items-center justify-center\" style=\"background:linear-gradient(135deg,#62e6ff,#65f0b7);\" data-kid=\"3\">\n      <i class=\"ti ti-bolt text-[#07090d] text-sm font-bold\" data-kid=\"4\"></i>\n    </div>\n    <nav class=\"flex flex-col gap-3 mt-4\" data-kid=\"5\">\n      <button class=\"w-10 h-10 rounded-sm flex items-center justify-center text-[#94a3b8] hover:text-[#62e6ff] transition-colors\" style=\"background:rgba(255,255,255,0.04);\" data-kid=\"6\">\n        <i class=\"ti ti-layout-dashboard text-lg\" data-kid=\"7\"></i>\n      </button>\n      <button class=\"w-10 h-10 rounded-sm flex items-center justify-center text-[#62e6ff]\" style=\"background:rgba(98,230,255,0.12); border:1px solid rgba(98,230,255,0.25);\" data-kid=\"8\">\n        <i class=\"ti ti-shopping-bag text-lg\" data-kid=\"9\"></i>\n      </button>\n      <button class=\"w-10 h-10 rounded-sm flex items-center justify-center text-[#94a3b8] hover:text-[#62e6ff] transition-colors\" style=\"background:rgba(255,255,255,0.04);\" data-kid=\"10\">\n        <i class=\"ti ti-chart-bar text-lg\" data-kid=\"11\"></i>\n      </button>\n      <button class=\"w-10 h-10 rounded-sm flex items-center justify-center text-[#94a3b8] hover:text-[#62e6ff] transition-colors\" style=\"background:rgba(255,255,255,0.04);\" data-kid=\"12\">\n        <i class=\"ti ti-calculator text-lg\" data-kid=\"13\"></i>\n      </button>\n      <button class=\"w-10 h-10 rounded-sm flex items-center justify-center text-[#94a3b8] hover:text-[#62e6ff] transition-colors\" style=\"background:rgba(255,255,255,0.04);\" data-kid=\"14\">\n        <i class=\"ti ti-flask text-lg\" data-kid=\"15\"></i>\n      </button>\n    </nav>\n    <div class=\"mt-auto w-8 h-8 rounded-full overflow-hidden border border-white/20\" data-kid=\"16\">\n      <img src=\"https://i.pravatar.cc/32?u=vendor1\" decoding=\"async\" loading=\"lazy\" class=\"w-full h-full object-cover\" data-kid=\"17\">\n    </div>\n  </aside>\n\n  \n  <div class=\"flex-1 flex flex-col overflow-hidden\" data-kid=\"18\">\n\n    \n    <header class=\"h-14 flex items-center justify-between px-8 border-b border-white/[0.08] shrink-0\" style=\"background:rgba(7,9,13,0.8); backdrop-filter:blur(16px);\" data-kid=\"19\">\n      <div class=\"flex items-center gap-2 text-sm\" data-kid=\"20\">\n        <button class=\"flex items-center gap-1.5 text-[#94a3b8] hover:text-white transition-colors\" data-kid=\"21\">\n          <i class=\"ti ti-arrow-left text-xs\" data-kid=\"22\"></i>\n          <span data-kid=\"23\">Resultados</span>\n        </button>\n        <i class=\"ti ti-chevron-right text-[#94a3b8] text-xs\" data-kid=\"24\"></i>\n        <span class=\"text-[#f8fafc] font-medium\" data-kid=\"25\">Mini Impressora Térmica Portátil</span>\n      </div>\n      <div class=\"flex items-center gap-3\" data-kid=\"26\">\n        <button class=\"flex items-center gap-2 px-4 py-2 rounded-sm text-sm text-[#94a3b8] border border-white/[0.12] hover:border-white/25 transition-colors\" style=\"background:rgba(255,255,255,0.05);\" data-kid=\"27\">\n          <i class=\"ti ti-heart text-xs\" data-kid=\"28\"></i> Salvar\n        </button>\n        <button class=\"flex items-center gap-2 px-4 py-2 rounded-sm text-sm font-medium text-[#07090d]\" style=\"background:linear-gradient(135deg,#62e6ff,#65f0b7);\" data-kid=\"29\">\n          <i class=\"ti ti-calculator text-xs\" data-kid=\"30\"></i> Simular Lucro\n        </button>\n      </div>\n    </header>\n\n    \n    <div class=\"flex-1 overflow-y-auto px-8 py-7 space-y-6\" style=\"background:radial-gradient(ellipse 80% 50% at 50% -20%, rgba(98,230,255,0.06) 0%, transparent 60%);\" data-kid=\"31\">\n\n      \n      <div class=\"rounded-xl p-7 flex gap-10\" style=\"background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.12); backdrop-filter:blur(16px);\" data-kid=\"32\">\n\n        \n        <div class=\"flex-[3] flex flex-col gap-5\" data-kid=\"33\">\n          \n          <div class=\"inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold tracking-wider w-fit\" style=\"background:rgba(98,230,255,0.15); border:1px solid rgba(98,230,255,0.3); color:#62e6ff;\" data-kid=\"34\">\n            <i class=\"ti ti-sparkles text-xs\" data-kid=\"35\"></i> #1 ESCOLHA DA IA\n          </div>\n\n          \n          <div data-kid=\"36\">\n            <h1 class=\"text-4xl font-bold tracking-tight leading-tight text-[#f8fafc]\" data-kid=\"37\">Mini Impressora<br data-kid=\"38\">Térmica Portátil</h1>\n          </div>\n\n          \n          <div class=\"flex items-center gap-2 flex-wrap\" data-kid=\"39\">\n            <span class=\"px-2.5 py-1 rounded text-xs font-medium\" style=\"background:rgba(255,111,36,0.15); border:1px solid rgba(255,111,36,0.3); color:#ff9d6b;\" data-kid=\"40\">\n              <i class=\"ti ti-brand-shopee text-xs mr-1\" data-kid=\"41\"></i>Shopee\n            </span>\n            <span class=\"px-2.5 py-1 rounded text-xs font-medium\" style=\"background:rgba(98,230,255,0.1); border:1px solid rgba(98,230,255,0.2); color:#62e6ff;\" data-kid=\"42\">\n              <i class=\"ti ti-cpu text-xs mr-1\" data-kid=\"43\"></i>Tecnologia\n            </span>\n            <span class=\"px-2.5 py-1 rounded text-xs font-medium\" style=\"background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.14); color:#94a3b8;\" data-kid=\"44\">\n              <i class=\"ti ti-user text-xs mr-1\" data-kid=\"45\"></i>Vendedor\n            </span>\n          </div>\n\n          \n          <div class=\"flex items-center gap-6\" data-kid=\"46\">\n            \n            <div class=\"relative flex items-center justify-center shrink-0\" style=\"width:110px; height:110px;\" data-kid=\"47\">\n              <svg viewBox=\"0 0 110 110\" width=\"110\" height=\"110\" class=\"absolute inset-0\" style=\"transform:rotate(-90deg);\" data-kid=\"48\">\n                <circle cx=\"55\" cy=\"55\" r=\"46\" fill=\"none\" stroke=\"rgba(255,255,255,0.08)\" stroke-width=\"8\" data-kid=\"49\"></circle>\n                <circle cx=\"55\" cy=\"55\" r=\"46\" fill=\"none\" stroke=\"url(#scoreGrad)\" stroke-width=\"8\" stroke-linecap=\"round\" stroke-dasharray=\"289\" stroke-dashoffset=\"37.6\" data-kid=\"50\"></circle>\n                <defs data-kid=\"51\">\n                  <linearGradient id=\"scoreGrad\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"0%\" data-kid=\"52\">\n                    <stop offset=\"0%\" stop-color=\"#65f0b7\" data-kid=\"53\"></stop>\n                    <stop offset=\"100%\" stop-color=\"#62e6ff\" data-kid=\"54\"></stop>\n                  </linearGradient>\n                </defs>\n              </svg>\n              <div class=\"text-center z-10\" data-kid=\"55\">\n                <div class=\"text-2xl font-bold text-[#f8fafc]\" style=\"font-family:'JetBrains Mono',monospace;\" data-kid=\"56\">87</div>\n                <div class=\"text-xs text-[#94a3b8]\" data-kid=\"57\">/100</div>\n              </div>\n            </div>\n\n            \n            <div class=\"grid grid-cols-2 gap-3 flex-1\" data-kid=\"58\">\n              <div class=\"p-3.5 rounded-lg\" style=\"background:rgba(101,240,183,0.08); border:1px solid rgba(101,240,183,0.2);\" data-kid=\"59\">\n                <div class=\"text-xs text-[#94a3b8] mb-1\" data-kid=\"60\">Margem Estimada</div>\n                <div class=\"text-2xl font-bold\" style=\"color:#65f0b7; font-family:'JetBrains Mono',monospace;\" data-kid=\"61\">38%</div>\n              </div>\n              <div class=\"p-3.5 rounded-lg\" style=\"background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.12);\" data-kid=\"62\">\n                <div class=\"text-xs text-[#94a3b8] mb-1\" data-kid=\"63\">Lucro por Unidade</div>\n                <div class=\"text-2xl font-bold text-[#f8fafc]\" style=\"font-family:'JetBrains Mono',monospace;\" data-kid=\"64\">R$147</div>\n              </div>\n              <div class=\"p-3.5 rounded-lg\" style=\"background:rgba(98,230,255,0.08); border:1px solid rgba(98,230,255,0.2);\" data-kid=\"65\">\n                <div class=\"text-xs text-[#94a3b8] mb-1\" data-kid=\"66\">Conversão Est.</div>\n                <div class=\"text-2xl font-bold\" style=\"color:#62e6ff; font-family:'JetBrains Mono',monospace;\" data-kid=\"67\">4.2%</div>\n              </div>\n              <div class=\"p-3.5 rounded-lg\" style=\"background:rgba(34,197,94,0.08); border:1px solid rgba(34,197,94,0.2);\" data-kid=\"68\">\n                <div class=\"text-xs text-[#94a3b8] mb-1\" data-kid=\"69\">Risco</div>\n                <div class=\"flex items-center gap-1.5\" data-kid=\"70\">\n                  <div class=\"w-2 h-2 rounded-full bg-[#22c55e]\" data-kid=\"71\"></div>\n                  <div class=\"text-lg font-semibold text-[#22c55e]\" data-kid=\"72\">Baixo</div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"flex-[2] flex flex-col\" data-kid=\"73\">\n          <div class=\"text-xs font-semibold tracking-widest text-[#94a3b8] uppercase mb-3\" data-kid=\"74\">Score por Dimensão</div>\n          <div class=\"flex-1 flex items-center justify-center\" style=\"min-height:260px;\" data-kid=\"75\">\n            <canvas id=\"radarChart\" width=\"280\" height=\"260\" data-kid=\"76\"></canvas>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"rounded-xl p-6\" style=\"background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.12); border-left:3px solid #8b5cf6; backdrop-filter:blur(16px);\" data-kid=\"77\">\n        <div class=\"flex items-center gap-2.5 mb-4\" data-kid=\"78\">\n          <div class=\"w-8 h-8 rounded-lg flex items-center justify-center\" style=\"background:rgba(139,92,246,0.2); border:1px solid rgba(139,92,246,0.3);\" data-kid=\"79\">\n            <i class=\"ti ti-robot text-sm\" style=\"color:#8b5cf6;\" data-kid=\"80\"></i>\n          </div>\n          <span class=\"text-sm font-semibold text-[#f8fafc]\" data-kid=\"81\">Análise da IA</span>\n          <span class=\"ml-auto text-xs px-2 py-0.5 rounded-full\" style=\"background:rgba(139,92,246,0.15); color:#8b5cf6; border:1px solid rgba(139,92,246,0.25);\" data-kid=\"82\">GPT-4 Turbo</span>\n        </div>\n        <p class=\"text-[#94a3b8] text-sm leading-relaxed\" data-kid=\"83\">\n          A mini impressora térmica tem apresentado crescimento consistente de demanda na Shopee Brasil, especialmente nas categorias de escritório e home office. Seu peso reduzido (&lt; 300g) mantém fretes baixos, preservando margem mesmo em vendas com frete grátis. A concorrência é <strong class=\"text-[#f8fafc]\" data-kid=\"84\">moderada — menos de 50 sellers com estoque ativo</strong>, o que indica uma janela de oportunidade clara. O produto beneficia de alta frequência de busca orgânica e forte apelo visual em conteúdo de vídeo curto, tornando-o ideal para estratégias combinadas de marketplace + redes sociais.\n        </p>\n      </div>\n\n      \n      <div class=\"grid grid-cols-2 gap-5\" data-kid=\"85\">\n        <div class=\"rounded-xl p-6\" style=\"background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.1);\" data-kid=\"86\">\n          <div class=\"flex items-center gap-2 mb-5\" data-kid=\"87\">\n            <div class=\"w-7 h-7 rounded-lg flex items-center justify-center\" style=\"background:rgba(101,240,183,0.15);\" data-kid=\"88\">\n              <i class=\"ti ti-circle-check text-sm\" style=\"color:#65f0b7;\" data-kid=\"89\"></i>\n            </div>\n            <span class=\"text-sm font-semibold text-[#f8fafc]\" data-kid=\"90\">Pontos Positivos</span>\n          </div>\n          <ul class=\"space-y-3\" data-kid=\"91\">\n            <li class=\"flex items-start gap-2.5 text-sm\" data-kid=\"92\">\n              <i class=\"ti ti-check mt-0.5 text-xs shrink-0\" style=\"color:#65f0b7;\" data-kid=\"93\"></i>\n              <span class=\"text-[#94a3b8]\" data-kid=\"94\">Margem acima de 35% mesmo com frete grátis</span>\n            </li>\n            <li class=\"flex items-start gap-2.5 text-sm\" data-kid=\"95\">\n              <i class=\"ti ti-check mt-0.5 text-xs shrink-0\" style=\"color:#65f0b7;\" data-kid=\"96\"></i>\n              <span class=\"text-[#94a3b8]\" data-kid=\"97\">Produto leve — custo de envio reduzido</span>\n            </li>\n            <li class=\"flex items-start gap-2.5 text-sm\" data-kid=\"98\">\n              <i class=\"ti ti-check mt-0.5 text-xs shrink-0\" style=\"color:#65f0b7;\" data-kid=\"99\"></i>\n              <span class=\"text-[#94a3b8]\" data-kid=\"100\">Alta procura com demanda crescente nos últimos 90 dias</span>\n            </li>\n            <li class=\"flex items-start gap-2.5 text-sm\" data-kid=\"101\">\n              <i class=\"ti ti-check mt-0.5 text-xs shrink-0\" style=\"color:#65f0b7;\" data-kid=\"102\"></i>\n              <span class=\"text-[#94a3b8]\" data-kid=\"103\">Diferencial visual para vídeos demonstrativos (TikTok, Reels)</span>\n            </li>\n            <li class=\"flex items-start gap-2.5 text-sm\" data-kid=\"104\">\n              <i class=\"ti ti-check mt-0.5 text-xs shrink-0\" style=\"color:#65f0b7;\" data-kid=\"105\"></i>\n              <span class=\"text-[#94a3b8]\" data-kid=\"106\">Recompra frequente via papel térmico — LTV alto</span>\n            </li>\n          </ul>\n        </div>\n\n        <div class=\"rounded-xl p-6\" style=\"background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.1);\" data-kid=\"107\">\n          <div class=\"flex items-center gap-2 mb-5\" data-kid=\"108\">\n            <div class=\"w-7 h-7 rounded-lg flex items-center justify-center\" style=\"background:rgba(248,184,92,0.15);\" data-kid=\"109\">\n              <i class=\"ti ti-alert-triangle text-sm\" style=\"color:#f8b85c;\" data-kid=\"110\"></i>\n            </div>\n            <span class=\"text-sm font-semibold text-[#f8fafc]\" data-kid=\"111\">Pontos de Atenção</span>\n          </div>\n          <ul class=\"space-y-3\" data-kid=\"112\">\n            <li class=\"flex items-start gap-2.5 text-sm\" data-kid=\"113\">\n              <i class=\"ti ti-point mt-0.5 text-xs shrink-0\" style=\"color:#f8b85c;\" data-kid=\"114\"></i>\n              <span class=\"text-[#94a3b8]\" data-kid=\"115\">Dependência de insumo recorrente (papel térmico)</span>\n            </li>\n            <li class=\"flex items-start gap-2.5 text-sm\" data-kid=\"116\">\n              <i class=\"ti ti-point mt-0.5 text-xs shrink-0\" style=\"color:#f8b85c;\" data-kid=\"117\"></i>\n              <span class=\"text-[#94a3b8]\" data-kid=\"118\">Produto importado — prazo de reposição pode ser longo</span>\n            </li>\n            <li class=\"flex items-start gap-2.5 text-sm\" data-kid=\"119\">\n              <i class=\"ti ti-point mt-0.5 text-xs shrink-0\" style=\"color:#f8b85c;\" data-kid=\"120\"></i>\n              <span class=\"text-[#94a3b8]\" data-kid=\"121\">Requer demonstração para converter — não é autoexplicativo</span>\n            </li>\n          </ul>\n        </div>\n      </div>\n\n      \n      <div class=\"grid grid-cols-3 gap-5\" data-kid=\"122\">\n\n        \n        <div class=\"col-span-1 rounded-xl p-6\" style=\"background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.1);\" data-kid=\"123\">\n          <div class=\"text-xs font-semibold tracking-widest text-[#94a3b8] uppercase mb-4\" data-kid=\"124\">Estratégia</div>\n          \n          <div class=\"flex gap-0 rounded-lg overflow-hidden mb-5\" style=\"background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.1);\" data-kid=\"125\">\n            <button class=\"flex-1 py-2 text-xs font-semibold text-[#07090d]\" style=\"background:linear-gradient(135deg,#62e6ff,#65f0b7);\" data-kid=\"126\">Vendedor</button>\n            <button class=\"flex-1 py-2 text-xs font-medium text-[#94a3b8]\" data-kid=\"127\">Afiliado</button>\n          </div>\n          <p class=\"text-sm text-[#94a3b8] leading-relaxed\" data-kid=\"128\">Compre em lotes de 10–20 unidades para testar. Invista em vídeos curtos demonstrando uso real. Posicione frete grátis como diferencial. Monitore estoque do líder de mercado para ajustar preço e capturar picos de demanda.</p>\n        </div>\n\n        \n        <div class=\"col-span-1 rounded-xl p-6 flex flex-col gap-5\" style=\"background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.1);\" data-kid=\"129\">\n          <div data-kid=\"130\">\n            <div class=\"text-xs font-semibold tracking-widest text-[#94a3b8] uppercase mb-3\" data-kid=\"131\">Público-Alvo</div>\n            <div class=\"flex flex-wrap gap-2\" data-kid=\"132\">\n              <span class=\"px-2.5 py-1 rounded text-xs\" style=\"background:rgba(255,255,255,0.07); color:#94a3b8; border:1px solid rgba(255,255,255,0.1);\" data-kid=\"133\">Estudantes</span>\n              <span class=\"px-2.5 py-1 rounded text-xs\" style=\"background:rgba(255,255,255,0.07); color:#94a3b8; border:1px solid rgba(255,255,255,0.1);\" data-kid=\"134\">Home Office</span>\n              <span class=\"px-2.5 py-1 rounded text-xs\" style=\"background:rgba(255,255,255,0.07); color:#94a3b8; border:1px solid rgba(255,255,255,0.1);\" data-kid=\"135\">Pequenos Negócios</span>\n              <span class=\"px-2.5 py-1 rounded text-xs\" style=\"background:rgba(255,255,255,0.07); color:#94a3b8; border:1px solid rgba(255,255,255,0.1);\" data-kid=\"136\">Festas e Eventos</span>\n            </div>\n          </div>\n          <div class=\"border-t border-white/[0.08] pt-5\" data-kid=\"137\">\n            <div class=\"text-xs font-semibold tracking-widest text-[#94a3b8] uppercase mb-3\" data-kid=\"138\">Faixa de Preço Sugerida</div>\n            <div class=\"flex items-end gap-2\" data-kid=\"139\">\n              <span class=\"text-2xl font-bold text-[#f8fafc]\" style=\"font-family:'JetBrains Mono',monospace;\" data-kid=\"140\">R$89–119</span>\n            </div>\n            <div class=\"text-xs text-[#94a3b8] mt-1\" data-kid=\"141\">Margem alvo: <span style=\"color:#65f0b7;\" data-kid=\"142\">35–42%</span></div>\n          </div>\n        </div>\n\n        \n        <div class=\"col-span-1 rounded-xl p-6\" style=\"background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.1);\" data-kid=\"143\">\n          <div class=\"flex items-center justify-between mb-4\" data-kid=\"144\">\n            <div class=\"text-xs font-semibold tracking-widest text-[#94a3b8] uppercase\" data-kid=\"145\">Tendência 30 dias</div>\n            <span class=\"text-xs px-2 py-0.5 rounded-full flex items-center gap-1\" style=\"background:rgba(101,240,183,0.12); color:#65f0b7; border:1px solid rgba(101,240,183,0.2);\" data-kid=\"146\">\n              <i class=\"ti ti-trending-up text-xs\" data-kid=\"147\"></i> +23%\n            </span>\n          </div>\n          <canvas id=\"trendMiniChart\" height=\"130\" data-kid=\"148\"></canvas>\n        </div>\n\n      </div>\n\n    </div>\n  </div>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/chart.js\" data-kid=\"149\"></script>\n<script data-kid=\"150\">\n  // Radar Chart\n  const radarCtx = document.getElementById('radarChart').getContext('2d');\n  new Chart(radarCtx, {\n    type: 'radar',\n    data: {\n      labels: ['Margem', 'Conversão', 'Demanda', 'Risco Inv.', 'Marg. Líq.'],\n      datasets: [{\n        data: [87, 72, 85, 90, 80],\n        backgroundColor: 'rgba(98,230,255,0.15)',\n        borderColor: '#62e6ff',\n        borderWidth: 2,\n        pointBackgroundColor: '#62e6ff',\n        pointRadius: 4,\n        pointHoverRadius: 6\n      }]\n    },\n    options: {\n      responsive: true,\n      maintainAspectRatio: false,\n      plugins: { legend: { display: false } },\n      scales: {\n        r: {\n          beginAtZero: true,\n          max: 100,\n          grid: { color: 'rgba(255,255,255,0.08)' },\n          angleLines: { color: 'rgba(255,255,255,0.08)' },\n          pointLabels: { color: '#94a3b8', font: { size: 11, family: 'Inter' } },\n          ticks: { display: false }\n        }\n      }\n    }\n  });\n\n  // Trend mini chart\n  const trendCtx = document.getElementById('trendMiniChart').getContext('2d');\n  const labels = Array.from({length: 30}, (_, i) => `D${i+1}`);\n  const data = [52,55,50,58,60,57,62,65,63,68,66,70,72,69,75,78,74,80,82,79,85,87,83,90,88,92,89,94,91,95];\n  const gradient = trendCtx.createLinearGradient(0, 0, 0, 130);\n  gradient.addColorStop(0, 'rgba(101,240,183,0.3)');\n  gradient.addColorStop(1, 'rgba(101,240,183,0)');\n  new Chart(trendCtx, {\n    type: 'line',\n    data: {\n      labels,\n      datasets: [{\n        data,\n        fill: true,\n        backgroundColor: gradient,\n        borderColor: '#65f0b7',\n        borderWidth: 2,\n        pointRadius: 0,\n        tension: 0.4\n      }]\n    },\n    options: {\n      responsive: true,\n      maintainAspectRatio: false,\n      plugins: { legend: { display: false }, tooltip: { enabled: false } },\n      scales: {\n        x: { display: false },\n        y: { display: false }\n      }\n    }\n  });\n</script>\n",
