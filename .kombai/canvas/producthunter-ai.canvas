            <div style=\"display: flex; gap: 6px; margin-top: 8px; flex-wrap: wrap;\" data-kid=\"296\">\n              <span style=\"font-size: 10px; background: rgba(139,92,246,0.15); color: #a78bfa; padding: 2px 8px; border-radius: 4px; font-weight: 600;\" data-kid=\"297\">Favorável</span>\n              <span style=\"font-size: 10px; background: rgba(101,240,183,0.10); color: #65f0b7; padding: 2px 8px; border-radius: 4px; font-weight: 600;\" data-kid=\"298\">Tech ↑</span>\n              <span style=\"font-size: 10px; background: rgba(248,184,92,0.10); color: #f8b85c; padding: 2px 8px; border-radius: 4px; font-weight: 600;\" data-kid=\"299\">Risco Médio</span>\n            </div>\n          </div>\n        </div>\n\n      </div>\n      \n    </div>\n    \n  </div>\n  \n</div>\n\n<style data-kid=\"300\">\n  @keyframes pulse {\n    0%, 100% { opacity: 1; box-shadow: 0 0 8px #65f0b7; }\n    50% { opacity: 0.5; box-shadow: 0 0 16px #65f0b7; }\n  }\n</style>\n\n<script data-kid=\"301\">\n  // Trend Chart\n  (function() {\n    const ctx = document.getElementById('trendChart').getContext('2d');\n    const labels = Array.from({length: 30}, (_, i) => {\n      const d = new Date(2025, 4, 1 + i);\n      return (i % 5 === 0) ? `${d.getDate()}/${d.getMonth()+1}` : '';\n    });\n    const datasets = [\n      {\n        label: 'Tecnologia',\n        data: [68,71,69,73,77,75,80,82,79,84,87,85,89,91,88,90,87,84,86,88,91,89,87,90,92,91,88,90,87,92],\n        borderColor: '#62e6ff',\n        backgroundColor: 'rgba(98,230,255,0.08)',\n        fill: true, tension: 0.4, pointRadius: 0, borderWidth: 2,\n      },\n      {\n        label: 'Beleza',\n        data: [55,57,60,58,62,65,63,67,69,68,71,73,72,76,78,75,80,82,79,84,82,80,83,85,84,86,84,87,85,87],\n        borderColor: '#65f0b7',\n        backgroundColor: 'rgba(101,240,183,0.06)',\n        fill: true, tension: 0.4, pointRadius: 0, borderWidth: 2,\n      },\n      {\n        label: 'Casa',\n        data: [50,52,54,53,56,55,58,60,57,62,60,63,65,63,67,65,68,70,67,72,70,74,72,75,73,77,74,76,74,74],\n        borderColor: '#f8b85c',\n        backgroundColor: 'rgba(248,184,92,0.05)',\n        fill: true, tension: 0.4, pointRadius: 0, borderWidth: 1.5,\n      },\n      {\n        label: 'Games',\n        data: [60,62,65,63,67,70,68,72,74,73,76,78,77,80,82,79,81,83,80,83,81,79,82,80,83,80,82,81,82,83],\n        borderColor: '#8b5cf6',\n        backgroundColor: 'rgba(139,92,246,0.06)',\n        fill: true, tension: 0.4, pointRadius: 0, borderWidth: 1.5,\n      }\n    ];\n    new Chart(ctx, {\n      type: 'line',\n      data: { labels, datasets },\n      options: {\n        responsive: true,\n        animation: { duration: 1200, easing: 'easeInOutQuart' },\n        plugins: {\n          legend: {\n            position: 'top',\n            align: 'end',\n            labels: { color: '#94a3b8', font: { family: 'Inter', size: 11 }, boxWidth: 12, padding: 16, usePointStyle: true }\n          },\n          tooltip: {\n            backgroundColor: 'rgba(16,20,27,0.95)',\n            borderColor: 'rgba(255,255,255,0.12)',\n            borderWidth: 1,\n            titleColor: '#f8fafc',\n            bodyColor: '#94a3b8',\n            padding: 10,\n          }\n        },\n        scales: {\n          x: {\n            grid: { color: 'rgba(255,255,255,0.04)', drawTicks: false },\n            ticks: { color: '#475569', font: { family: 'Inter', size: 10 }, maxRotation: 0 },\n            border: { color: 'rgba(255,255,255,0.06)' }\n          },\n          y: {\n            min: 40, max: 100,\n            grid: { color: 'rgba(255,255,255,0.05)', drawTicks: false },\n            ticks: { color: '#475569', font: { family: 'Inter', size: 10 }, stepSize: 20 },\n            border: { color: 'rgba(255,255,255,0.06)', dash: [4, 4] }\n          }\n        },\n        interaction: { mode: 'index', intersect: false }\n      }\n    });\n  })();\n\n  // Radar Chart\n  (function() {\n    const ctx = document.getElementById('radarChart').getContext('2d');\n    new Chart(ctx, {\n      type: 'radar',\n      data: {\n        labels: ['Volume', 'Margem', 'Concorrência', 'Taxas', 'Conversão'],\n        datasets: [\n          {\n            label: 'Shopee',\n            data: [82, 70, 55, 72, 78],\n            borderColor: '#65f0b7', backgroundColor: 'rgba(101,240,183,0.10)',\n            borderWidth: 2, pointBackgroundColor: '#65f0b7', pointRadius: 3,\n          },\n          {\n            label: 'Amazon',\n            data: [88, 65, 60, 60, 85],\n            borderColor: '#62e6ff', backgroundColor: 'rgba(98,230,255,0.08)',\n            borderWidth: 2, pointBackgroundColor: '#62e6ff', pointRadius: 3,\n          },\n          {\n            label: 'Mercado Livre',\n            data: [92, 62, 68, 55, 80],\n            borderColor: '#8b5cf6', backgroundColor: 'rgba(139,92,246,0.08)',\n            borderWidth: 2, pointBackgroundColor: '#8b5cf6', pointRadius: 3,\n          }\n        ]\n      },\n      options: {\n        responsive: true,\n        animation: { duration: 1200 },\n        plugins: {\n          legend: {\n            position: 'bottom',\n            labels: { color: '#94a3b8', font: { family: 'Inter', size: 10 }, boxWidth: 10, padding: 12, usePointStyle: true }\n          },\n          tooltip: {\n            backgroundColor: 'rgba(16,20,27,0.95)',\n            borderColor: 'rgba(255,255,255,0.12)',\n            borderWidth: 1,\n            titleColor: '#f8fafc',\n            bodyColor: '#94a3b8',\n          }\n        },\n        scales: {\n          r: {\n            min: 40, max: 100,\n            grid: { color: 'rgba(255,255,255,0.08)' },\n            angleLines: { color: 'rgba(255,255,255,0.06)' },\n            pointLabels: { color: '#64748b', font: { family: 'Inter', size: 11 } },\n            ticks: { display: false, stepSize: 20 }\n          }\n        }\n      }\n    });\n  })();\n\n  // Scatter Chart\n  (function() {\n    const ctx = document.getElementById('scatterChart').getContext('2d');\n    const lowRisk = [\n      {x: 38, y: 2.1, r: 8},\n      {x: 44, y: 1.8, r: 10},\n      {x: 42, y: 2.4, r: 7},\n      {x: 36, y: 3.0, r: 6},\n      {x: 50, y: 2.0, r: 9},\n      {x: 33, y: 2.7, r: 5},\n    ];\n    const midRisk = [\n      {x: 28, y: 4.5, r: 7},\n      {x: 30, y: 5.0, r: 8},\n      {x: 25, y: 4.2, r: 6},\n      {x: 35, y: 4.8, r: 5},\n    ];\n    const highRisk = [\n      {x: 20, y: 7.5, r: 6},\n      {x: 18, y: 8.2, r: 7},\n      {x: 15, y: 7.0, r: 5},\n      {x: 22, y: 8.8, r: 6},\n      {x: 12, y: 9.1, r: 5},\n    ];\n    new Chart(ctx, {\n      type: 'bubble',\n      data: {\n        datasets: [\n          {\n            label: 'Baixo Risco',\n            data: lowRisk,\n            backgroundColor: 'rgba(101,240,183,0.55)',\n            borderColor: '#65f0b7',\n            borderWidth: 1.5,\n          },\n          {\n            label: 'Risco Médio',\n            data: midRisk,\n            backgroundColor: 'rgba(98,230,255,0.40)',\n            borderColor: '#62e6ff',\n            borderWidth: 1.5,\n          },\n          {\n            label: 'Alto Risco',\n            data: highRisk,\n            backgroundColor: 'rgba(248,184,92,0.50)',\n            borderColor: '#f8b85c',\n            borderWidth: 1.5,\n          }\n        ]\n      },\n      options: {\n        responsive: true,\n        animation: { duration: 1200 },\n        plugins: {\n          legend: {\n            position: 'top',\n            align: 'end',\n            labels: { color: '#94a3b8', font: { family: 'Inter', size: 11 }, boxWidth: 10, padding: 12, usePointStyle: true }\n          },\n          tooltip: {\n            backgroundColor: 'rgba(16,20,27,0.95)',\n            borderColor: 'rgba(255,255,255,0.12)',\n            borderWidth: 1,\n            titleColor: '#f8fafc',\n            bodyColor: '#94a3b8',\n            callbacks: {\n              label: function(ctx) {\n                return `Margem: ${ctx.parsed.x}% | Risco: ${ctx.parsed.y}/10`;\n              }\n            }\n          }\n        },\n        scales: {\n          x: {\n            title: {\n              display: true,\n              text: 'Margem (%)',\n              color: '#475569',\n              font: { family: 'Inter', size: 11 }\n            },\n            min: 5, max: 60,\n            grid: { color: 'rgba(255,255,255,0.04)' },\n            ticks: { color: '#475569', font: { family: 'Inter', size: 10 } },\n            border: { color: 'rgba(255,255,255,0.06)' }\n          },\n          y: {\n            title: {\n              display: true,\n              text: 'Risco (0-10)',\n              color: '#475569',\n              font: { family: 'Inter', size: 11 }\n            },\n            min: 0, max: 10,\n            grid: { color: 'rgba(255,255,255,0.04)' },\n            ticks: { color: '#475569', font: { family: 'Inter', size: 10 }, stepSize: 2 },\n            border: { color: 'rgba(255,255,255,0.06)' }\n          }\n        }\n      }\n    });\n  })();\n</script>\n",
