      "html": "<style data-kid=\"0\">\n@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');\n@import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n@keyframes shimmerBtn {\n  0% { background-position: -200% center; }\n  100% { background-position: 200% center; }\n}\n@keyframes orbFloat {\n  0%,100% { transform: translate(0,0) scale(1); }\n  33% { transform: translate(22px,-16px) scale(1.04); }\n  66% { transform: translate(-16px,11px) scale(0.97); }\n}\n@keyframes pulseGlow {\n  0%,100% { box-shadow: 0 0 5px rgba(101,240,183,0.5); }\n  50% { box-shadow: 0 0 11px rgba(101,240,183,0.9); }\n}\n</style>\n\n<div style=\"display:flex; min-height:1080px; background:#07090d; font-family:'Inter',sans-serif; color:#f8fafc; position:relative; overflow:hidden;\" data-kid=\"1\">\n\n  \n  <div style=\"position:absolute; inset:0; pointer-events:none; z-index:0; overflow:hidden;\" data-kid=\"2\">\n    <div style=\"position:absolute; width:640px; height:640px; border-radius:50%; background:radial-gradient(circle,rgba(98,230,255,0.055) 0%,transparent 70%); top:-180px; left:260px; animation:orbFloat 15s ease-in-out infinite;\" data-kid=\"3\"></div>\n    <div style=\"position:absolute; width:480px; height:480px; border-radius:50%; background:radial-gradient(circle,rgba(101,240,183,0.04) 0%,transparent 70%); bottom:-80px; right:180px; animation:orbFloat 19s ease-in-out infinite 3s;\" data-kid=\"4\"></div>\n    <div style=\"position:absolute; width:320px; height:320px; border-radius:50%; background:radial-gradient(circle,rgba(139,92,246,0.035) 0%,transparent 70%); top:320px; right:500px; animation:orbFloat 22s ease-in-out infinite 7s;\" data-kid=\"5\"></div>\n  </div>\n\n  \n  <aside style=\"width:240px; min-width:240px; background:rgba(7,9,13,0.96); border-right:1px solid rgba(255,255,255,0.08); display:flex; flex-direction:column; position:relative; z-index:10;\" data-kid=\"6\">\n    \n    <div style=\"padding:20px 18px 18px; display:flex; align-items:center; gap:12px; border-bottom:1px solid rgba(255,255,255,0.07);\" data-kid=\"7\">\n      <div style=\"width:34px; height:34px; background:linear-gradient(135deg,#62e6ff 0%,#65f0b7 100%); border-radius:10px; display:flex; align-items:center; justify-content:center; flex-shrink:0; box-shadow:0 4px 18px rgba(98,230,255,0.32);\" data-kid=\"8\">\n        <i class=\"ti ti-bolt\" style=\"color:#07090d; font-size:17px;\" data-kid=\"9\"></i>\n      </div>\n      <div data-kid=\"10\">\n        <div style=\"font-size:13px; font-weight:700; letter-spacing:-0.02em; color:#f8fafc; line-height:1.2;\" data-kid=\"11\">ProductHunter</div>\n        <div style=\"font-size:10px; font-weight:800; color:#62e6ff; letter-spacing:0.14em; text-transform:uppercase;\" data-kid=\"12\">AI</div>\n      </div>\n    </div>\n    \n    <div style=\"padding:18px 18px 8px;\" data-kid=\"13\">\n      <span style=\"font-size:10px; font-weight:600; letter-spacing:0.1em; text-transform:uppercase; color:rgba(148,163,184,0.4);\" data-kid=\"14\">Menu</span>\n    </div>\n    \n    <nav style=\"flex:1; padding:0 8px; display:flex; flex-direction:column; gap:2px;\" data-kid=\"15\">\n      <a href=\"#\" style=\"display:flex; align-items:center; gap:10px; padding:9px 10px; border-radius:8px; font-size:13px; font-weight:500; color:#94a3b8; text-decoration:none;\" data-kid=\"16\">\n        <i class=\"ti ti-layout-dashboard\" style=\"font-size:16px; min-width:16px;\" data-kid=\"17\"></i><span data-kid=\"18\">Dashboard</span>\n      </a>\n      \n      <a href=\"#\" style=\"display:flex; align-items:center; gap:10px; padding:9px 10px; border-radius:8px; font-size:13px; font-weight:600; color:#62e6ff; text-decoration:none; background:rgba(98,230,255,0.08); border:1px solid rgba(98,230,255,0.15); position:relative;\" data-kid=\"19\">\n        <div style=\"position:absolute; left:0; top:7px; bottom:7px; width:2px; background:#62e6ff; border-radius:0 2px 2px 0;\" data-kid=\"20\"></div>\n        <i class=\"ti ti-user-circle\" style=\"font-size:16px; min-width:16px; color:#62e6ff; margin-left:8px;\" data-kid=\"21\"></i>\n        <span data-kid=\"22\">Perfil</span>\n        <span style=\"margin-left:auto; font-size:9px; background:rgba(98,230,255,0.15); padding:2px 7px; border-radius:100px; color:#62e6ff; font-weight:800; letter-spacing:0.04em;\" data-kid=\"23\">ATIVO</span>\n      </a>\n      <a href=\"#\" style=\"display:flex; align-items:center; gap:10px; padding:9px 10px; border-radius:8px; font-size:13px; font-weight:500; color:#94a3b8; text-decoration:none;\" data-kid=\"24\">\n        <i class=\"ti ti-chart-bar\" style=\"font-size:16px; min-width:16px;\" data-kid=\"25\"></i><span data-kid=\"26\">Resultados</span>\n      </a>\n      <a href=\"#\" style=\"display:flex; align-items:center; gap:10px; padding:9px 10px; border-radius:8px; font-size:13px; font-weight:500; color:#94a3b8; text-decoration:none;\" data-kid=\"27\">\n        <i class=\"ti ti-calculator\" style=\"font-size:16px; min-width:16px;\" data-kid=\"28\"></i><span data-kid=\"29\">Simulador</span>\n      </a>\n      <a href=\"#\" style=\"display:flex; align-items:center; gap:10px; padding:9px 10px; border-radius:8px; font-size:13px; font-weight:500; color:#94a3b8; text-decoration:none;\" data-kid=\"30\">\n        <i class=\"ti ti-flask\" style=\"font-size:16px; min-width:16px;\" data-kid=\"31\"></i><span data-kid=\"32\">Lab de IA</span>\n      </a>\n      <a href=\"#\" style=\"display:flex; align-items:center; gap:10px; padding:9px 10px; border-radius:8px; font-size:13px; font-weight:500; color:#94a3b8; text-decoration:none;\" data-kid=\"33\">\n        <i class=\"ti ti-heart\" style=\"font-size:16px; min-width:16px;\" data-kid=\"34\"></i><span data-kid=\"35\">Favoritos</span>\n      </a>\n    </nav>\n    \n    <div style=\"padding:12px 10px; border-top:1px solid rgba(255,255,255,0.07);\" data-kid=\"36\">\n      <div style=\"display:flex; align-items:center; gap:10px; padding:8px 10px; border-radius:8px; background:rgba(255,255,255,0.04);\" data-kid=\"37\">\n        <img src=\"https://i.pravatar.cc/32?u=carlos-silva-ph\" decoding=\"async\" loading=\"lazy\" style=\"width:28px; height:28px; border-radius:50%; border:1px solid rgba(98,230,255,0.32);\" data-kid=\"38\">\n        <div style=\"flex:1; min-width:0;\" data-kid=\"39\">\n          <div style=\"font-size:12px; font-weight:600; color:#f8fafc;\" data-kid=\"40\">Carlos Silva</div>\n          <div style=\"font-size:10px; color:#94a3b8;\" data-kid=\"41\">Plano Pro</div>\n        </div>\n        <i class=\"ti ti-dots-vertical\" style=\"font-size:14px; color:#94a3b8;\" data-kid=\"42\"></i>\n      </div>\n    </div>\n  </aside>\n\n  \n  <main style=\"flex:1; position:relative; z-index:5; padding:40px 52px 64px; overflow-y:auto;\" data-kid=\"43\">\n\n    \n    <div style=\"display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:36px;\" data-kid=\"44\">\n      <div data-kid=\"45\">\n        <div style=\"display:inline-flex; align-items:center; gap:7px; padding:4px 14px 4px 9px; border-radius:100px; background:rgba(98,230,255,0.08); border:1px solid rgba(98,230,255,0.2); font-size:11px; font-weight:700; color:#62e6ff; letter-spacing:0.06em; text-transform:uppercase; margin-bottom:16px;\" data-kid=\"46\">\n          <div style=\"width:6px; height:6px; border-radius:50%; background:#62e6ff; animation:pulseGlow 2s ease-in-out infinite;\" data-kid=\"47\"></div>\n          IA em tempo real\n        </div>\n        <h1 style=\"margin:0 0 10px; font-size:34px; font-weight:800; letter-spacing:-0.04em; color:#f8fafc; line-height:1.1;\" data-kid=\"48\">Simule seu Cenário</h1>\n        <p style=\"margin:0; font-size:15px; color:#94a3b8; max-width:520px; line-height:1.65;\" data-kid=\"49\">Informe seu perfil e receba um ranking personalizado de oportunidades baseado em dados de mercado.</p>\n      </div>\n      <div style=\"display:flex; align-items:center; gap:8px; flex-shrink:0; margin-top:6px;\" data-kid=\"50\">\n        <div style=\"padding:7px 14px; border-radius:8px; background:rgba(101,240,183,0.06); border:1px solid rgba(101,240,183,0.16); font-size:12px; color:#65f0b7; display:flex; align-items:center; gap:6px;\" data-kid=\"51\">\n          <div style=\"width:5px; height:5px; border-radius:50%; background:#65f0b7; box-shadow:0 0 6px #65f0b7;\" data-kid=\"52\"></div>\n          Dados atualizados\n        </div>\n        <div style=\"padding:7px 14px; border-radius:8px; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); font-size:12px; color:#94a3b8; display:flex; align-items:center; gap:6px; cursor:pointer;\" data-kid=\"53\">\n          <i class=\"ti ti-history\" style=\"font-size:13px;\" data-kid=\"54\"></i>\n          Histórico\n        </div>\n      </div>\n    </div>\n\n    \n    <div style=\"background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.1); border-radius:20px; overflow:hidden; backdrop-filter:blur(20px);\" data-kid=\"55\">\n\n      \n      <div style=\"padding:14px 32px; background:rgba(255,255,255,0.025); border-bottom:1px solid rgba(255,255,255,0.07); display:flex; align-items:center; gap:12px;\" data-kid=\"56\">\n        <div style=\"display:flex; gap:6px;\" data-kid=\"57\">\n          <div style=\"width:10px; height:10px; border-radius:50%; background:rgba(255,255,255,0.13);\" data-kid=\"58\"></div>\n          <div style=\"width:10px; height:10px; border-radius:50%; background:rgba(255,255,255,0.09);\" data-kid=\"59\"></div>\n          <div style=\"width:10px; height:10px; border-radius:50%; background:rgba(255,255,255,0.06);\" data-kid=\"60\"></div>\n        </div>\n        <span style=\"font-size:12px; color:rgba(148,163,184,0.5); letter-spacing:0.04em;\" data-kid=\"61\">consulta.perfil — ProductHunter AI</span>\n        <div style=\"margin-left:auto; font-size:11px; color:rgba(148,163,184,0.4); display:flex; align-items:center; gap:5px;\" data-kid=\"62\">\n          <i class=\"ti ti-clock\" style=\"font-size:12px;\" data-kid=\"63\"></i>\n          Estimativa: 30 segundos\n        </div>\n      </div>\n\n      <div style=\"padding:36px 40px;\" data-kid=\"64\">\n\n        \n        <div style=\"margin-bottom:32px;\" data-kid=\"65\">\n          <div style=\"display:flex; align-items:center; gap:10px; margin-bottom:16px;\" data-kid=\"66\">\n            <span style=\"font-size:10px; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; color:rgba(148,163,184,0.45); min-width:22px;\" data-kid=\"67\">01</span>\n            <span style=\"font-size:14px; font-weight:700; color:#f8fafc;\" data-kid=\"68\">Eu sou</span>\n            <span style=\"font-size:10px; color:rgba(239,68,68,0.7); font-weight:600; letter-spacing:0.04em;\" data-kid=\"69\">obrigatório</span>\n          </div>\n          <div style=\"display:flex; gap:10px; flex-wrap:wrap;\" data-kid=\"70\">\n            \n            <div style=\"display:flex; align-items:center; gap:9px; padding:11px 20px; border-radius:10px; border:1px solid rgba(98,230,255,0.55); background:rgba(98,230,255,0.09); cursor:pointer; box-shadow:0 0 18px rgba(98,230,255,0.1), inset 0 1px 0 rgba(98,230,255,0.1);\" data-kid=\"71\">\n              <i class=\"ti ti-store\" style=\"font-size:17px; color:#62e6ff;\" data-kid=\"72\"></i>\n              <span style=\"font-size:13px; font-weight:600; color:#62e6ff;\" data-kid=\"73\">Vendedor</span>\n            </div>\n            <div style=\"display:flex; align-items:center; gap:9px; padding:11px 20px; border-radius:10px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.04); cursor:pointer;\" data-kid=\"74\">\n              <i class=\"ti ti-users\" style=\"font-size:17px; color:#94a3b8;\" data-kid=\"75\"></i>\n              <span style=\"font-size:13px; font-weight:500; color:#94a3b8;\" data-kid=\"76\">Afiliado</span>\n            </div>\n            <div style=\"display:flex; align-items:center; gap:9px; padding:11px 20px; border-radius:10px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.04); cursor:pointer;\" data-kid=\"77\">\n              <i class=\"ti ti-truck-delivery\" style=\"font-size:17px; color:#94a3b8;\" data-kid=\"78\"></i>\n              <span style=\"font-size:13px; font-weight:500; color:#94a3b8;\" data-kid=\"79\">Dropshipping</span>\n            </div>\n            <div style=\"display:flex; align-items:center; gap:9px; padding:11px 20px; border-radius:10px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.04); cursor:pointer;\" data-kid=\"80\">\n              <i class=\"ti ti-arrows-exchange\" style=\"font-size:17px; color:#94a3b8;\" data-kid=\"81\"></i>\n              <span style=\"font-size:13px; font-weight:500; color:#94a3b8;\" data-kid=\"82\">Revendedor</span>\n            </div>\n            <div style=\"display:flex; align-items:center; gap:9px; padding:11px 20px; border-radius:10px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.04); cursor:pointer;\" data-kid=\"83\">\n              <i class=\"ti ti-building-store\" style=\"font-size:17px; color:#94a3b8;\" data-kid=\"84\"></i>\n              <span style=\"font-size:13px; font-weight:500; color:#94a3b8;\" data-kid=\"85\">Loja Própria</span>\n            </div>\n          </div>\n        </div>\n\n        <div style=\"height:1px; background:rgba(255,255,255,0.06); margin-bottom:32px;\" data-kid=\"86\"></div>\n\n        \n        <div style=\"margin-bottom:32px;\" data-kid=\"87\">\n          <div style=\"display:flex; align-items:center; gap:10px; margin-bottom:16px;\" data-kid=\"88\">\n            <span style=\"font-size:10px; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; color:rgba(148,163,184,0.45); min-width:22px;\" data-kid=\"89\">02</span>\n            <span style=\"font-size:14px; font-weight:700; color:#f8fafc;\" data-kid=\"90\">Quero atuar em</span>\n          </div>\n          <div style=\"display:flex; gap:10px; flex-wrap:wrap;\" data-kid=\"91\">\n            <div style=\"display:flex; align-items:center; gap:8px; padding:9px 16px; border-radius:10px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.04); cursor:pointer;\" data-kid=\"92\">\n              <div style=\"width:20px; height:20px; border-radius:5px; background:#ffe600; display:flex; align-items:center; justify-content:center; flex-shrink:0;\" data-kid=\"93\"><span style=\"font-size:7px; font-weight:900; color:#222;\" data-kid=\"94\">ML</span></div>\n              <span style=\"font-size:13px; color:#94a3b8; white-space:nowrap;\" data-kid=\"95\">Mercado Livre</span>\n            </div>\n            <div style=\"display:flex; align-items:center; gap:8px; padding:9px 16px; border-radius:10px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.04); cursor:pointer;\" data-kid=\"96\">\n              <div style=\"width:20px; height:20px; border-radius:5px; background:#ff9900; display:flex; align-items:center; justify-content:center; flex-shrink:0;\" data-kid=\"97\"><span style=\"font-size:11px; font-weight:900; color:#fff;\" data-kid=\"98\">a</span></div>\n              <span style=\"font-size:13px; color:#94a3b8; white-space:nowrap;\" data-kid=\"99\">Amazon</span>\n            </div>\n            \n            <div style=\"display:flex; align-items:center; gap:8px; padding:9px 16px; border-radius:10px; border:1px solid rgba(249,115,22,0.58); background:rgba(249,115,22,0.1); cursor:pointer; box-shadow:0 0 14px rgba(249,115,22,0.1);\" data-kid=\"100\">\n              <div style=\"width:20px; height:20px; border-radius:5px; background:#f97316; display:flex; align-items:center; justify-content:center; flex-shrink:0;\" data-kid=\"101\"><span style=\"font-size:11px; font-weight:900; color:#fff;\" data-kid=\"102\">S</span></div>\n              <span style=\"font-size:13px; font-weight:600; color:#f97316; white-space:nowrap;\" data-kid=\"103\">Shopee</span>\n            </div>\n            <div style=\"display:flex; align-items:center; gap:8px; padding:9px 16px; border-radius:10px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.04); cursor:pointer;\" data-kid=\"104\">\n              <div style=\"width:20px; height:20px; border-radius:5px; background:#e53935; display:flex; align-items:center; justify-content:center; flex-shrink:0;\" data-kid=\"105\"><span style=\"font-size:7px; font-weight:900; color:#fff;\" data-kid=\"106\">AE</span></div>\n              <span style=\"font-size:13px; color:#94a3b8; white-space:nowrap;\" data-kid=\"107\">AliExpress</span>\n            </div>\n            <div style=\"display:flex; align-items:center; gap:8px; padding:9px 16px; border-radius:10px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.04); cursor:pointer;\" data-kid=\"108\">\n              <div style=\"width:20px; height:20px; border-radius:5px; background:#010101; border:1px solid rgba(255,255,255,0.15); display:flex; align-items:center; justify-content:center; flex-shrink:0;\" data-kid=\"109\"><span style=\"font-size:7px; font-weight:900; color:#fff;\" data-kid=\"110\">TT</span></div>\n              <span style=\"font-size:13px; color:#94a3b8; white-space:nowrap;\" data-kid=\"111\">TikTok Shop</span>\n            </div>\n            <div style=\"display:flex; align-items:center; gap:8px; padding:9px 16px; border-radius:10px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.04); cursor:pointer;\" data-kid=\"112\">\n              <div style=\"width:20px; height:20px; border-radius:5px; background:#1565c0; display:flex; align-items:center; justify-content:center; flex-shrink:0;\" data-kid=\"113\"><span style=\"font-size:7px; font-weight:900; color:#fff;\" data-kid=\"114\">MG</span></div>\n              <span style=\"font-size:13px; color:#94a3b8; white-space:nowrap;\" data-kid=\"115\">Magalu</span>\n            </div>\n            <div style=\"display:flex; align-items:center; gap:8px; padding:9px 16px; border-radius:10px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.04); cursor:pointer;\" data-kid=\"116\">\n              <div style=\"width:20px; height:20px; border-radius:5px; background:#111; border:1px solid rgba(255,255,255,0.2); display:flex; align-items:center; justify-content:center; flex-shrink:0;\" data-kid=\"117\"><span style=\"font-size:7px; font-weight:900; color:#fff;\" data-kid=\"118\">SH</span></div>\n              <span style=\"font-size:13px; color:#94a3b8; white-space:nowrap;\" data-kid=\"119\">Shein</span>\n            </div>\n          </div>\n        </div>\n\n        <div style=\"height:1px; background:rgba(255,255,255,0.06); margin-bottom:32px;\" data-kid=\"120\"></div>\n\n        \n        <div style=\"margin-bottom:32px;\" data-kid=\"121\">\n          <div style=\"display:flex; align-items:center; gap:10px; margin-bottom:16px;\" data-kid=\"122\">\n            <span style=\"font-size:10px; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; color:rgba(148,163,184,0.45); min-width:22px;\" data-kid=\"123\">03</span>\n            <span style=\"font-size:14px; font-weight:700; color:#f8fafc;\" data-kid=\"124\">Nicho</span>\n          </div>\n          <div style=\"display:flex; flex-wrap:wrap; gap:8px;\" data-kid=\"125\">\n            <span style=\"padding:7px 16px; border-radius:100px; font-size:12px; font-weight:600; border:1px solid rgba(98,230,255,0.55); background:rgba(98,230,255,0.1); color:#62e6ff; cursor:pointer; white-space:nowrap;\" data-kid=\"126\">Tecnologia</span>\n            <span style=\"padding:7px 16px; border-radius:100px; font-size:12px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.04); color:#94a3b8; cursor:pointer; white-space:nowrap;\" data-kid=\"127\">Beleza</span>\n            <span style=\"padding:7px 16px; border-radius:100px; font-size:12px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.04); color:#94a3b8; cursor:pointer; white-space:nowrap;\" data-kid=\"128\">Casa</span>\n            <span style=\"padding:7px 16px; border-radius:100px; font-size:12px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.04); color:#94a3b8; cursor:pointer; white-space:nowrap;\" data-kid=\"129\">Brinquedos</span>\n            <span style=\"padding:7px 16px; border-radius:100px; font-size:12px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.04); color:#94a3b8; cursor:pointer; white-space:nowrap;\" data-kid=\"130\">Pets</span>\n            <span style=\"padding:7px 16px; border-radius:100px; font-size:12px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.04); color:#94a3b8; cursor:pointer; white-space:nowrap;\" data-kid=\"131\">Moda</span>\n            <span style=\"padding:7px 16px; border-radius:100px; font-size:12px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.04); color:#94a3b8; cursor:pointer; white-space:nowrap;\" data-kid=\"132\">Ferramentas</span>\n            <span style=\"padding:7px 16px; border-radius:100px; font-size:12px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.04); color:#94a3b8; cursor:pointer; white-space:nowrap;\" data-kid=\"133\">Automotivo</span>\n            <span style=\"padding:7px 16px; border-radius:100px; font-size:12px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.04); color:#94a3b8; cursor:pointer; white-space:nowrap;\" data-kid=\"134\">Decoração</span>\n            <span style=\"padding:7px 16px; border-radius:100px; font-size:12px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.04); color:#94a3b8; cursor:pointer; white-space:nowrap;\" data-kid=\"135\">Saúde</span>\n            <span style=\"padding:7px 16px; border-radius:100px; font-size:12px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.04); color:#94a3b8; cursor:pointer; white-space:nowrap;\" data-kid=\"136\">Esportes</span>\n            <span style=\"padding:7px 16px; border-radius:100px; font-size:12px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.04); color:#94a3b8; cursor:pointer; white-space:nowrap;\" data-kid=\"137\">Games</span>\n            <span style=\"padding:7px 16px; border-radius:100px; font-size:12px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.04); color:#94a3b8; cursor:pointer; white-space:nowrap;\" data-kid=\"138\">Papelaria</span>\n            <span style=\"padding:7px 16px; border-radius:100px; font-size:12px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.04); color:#94a3b8; cursor:pointer; white-space:nowrap;\" data-kid=\"139\">Cozinha</span>\n            <span style=\"padding:7px 16px; border-radius:100px; font-size:12px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.04); color:#94a3b8; cursor:pointer; white-space:nowrap;\" data-kid=\"140\">Organização</span>\n          </div>\n        </div>\n\n        <div style=\"height:1px; background:rgba(255,255,255,0.06); margin-bottom:32px;\" data-kid=\"141\"></div>\n\n        \n        <div style=\"display:grid; grid-template-columns:1fr 1fr; gap:40px; margin-bottom:32px;\" data-kid=\"142\">\n\n          \n          <div data-kid=\"143\">\n            <div style=\"display:flex; align-items:center; gap:10px; margin-bottom:16px;\" data-kid=\"144\">\n              <span style=\"font-size:10px; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; color:rgba(148,163,184,0.45); min-width:22px;\" data-kid=\"145\">04</span>\n              <span style=\"font-size:14px; font-weight:700; color:#f8fafc;\" data-kid=\"146\">Meu objetivo</span>\n            </div>\n            <div style=\"display:grid; grid-template-columns:1fr 1fr; gap:8px;\" data-kid=\"147\">\n              \n              <div style=\"padding:14px; border-radius:10px; border:1px solid rgba(101,240,183,0.5); background:rgba(101,240,183,0.07); cursor:pointer; box-shadow:0 0 16px rgba(101,240,183,0.08);\" data-kid=\"148\">\n                <i class=\"ti ti-coin\" style=\"font-size:20px; color:#65f0b7; display:block; margin-bottom:7px;\" data-kid=\"149\"></i>\n                <div style=\"font-size:12px; font-weight:600; color:#65f0b7; line-height:1.3;\" data-kid=\"150\">Maior Lucro</div>\n              </div>\n              <div style=\"padding:14px; border-radius:10px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.04); cursor:pointer;\" data-kid=\"151\">\n                <i class=\"ti ti-rocket\" style=\"font-size:20px; color:#94a3b8; display:block; margin-bottom:7px;\" data-kid=\"152\"></i>\n                <div style=\"font-size:12px; color:#94a3b8; line-height:1.3;\" data-kid=\"153\">Giro Rápido</div>\n              </div>\n              <div style=\"padding:14px; border-radius:10px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.04); cursor:pointer;\" data-kid=\"154\">\n                <i class=\"ti ti-shield-check\" style=\"font-size:20px; color:#94a3b8; display:block; margin-bottom:7px;\" data-kid=\"155\"></i>\n                <div style=\"font-size:12px; color:#94a3b8; line-height:1.3;\" data-kid=\"156\">Baixa Concorrência</div>\n              </div>\n              <div style=\"padding:14px; border-radius:10px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.04); cursor:pointer;\" data-kid=\"157\">\n                <i class=\"ti ti-chart-line\" style=\"font-size:20px; color:#94a3b8; display:block; margin-bottom:7px;\" data-kid=\"158\"></i>\n                <div style=\"font-size:12px; color:#94a3b8; line-height:1.3;\" data-kid=\"159\">Alta Conversão</div>\n              </div>\n              <div style=\"padding:14px; border-radius:10px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.04); cursor:pointer;\" data-kid=\"160\">\n                <i class=\"ti ti-flame\" style=\"font-size:20px; color:#94a3b8; display:block; margin-bottom:7px;\" data-kid=\"161\"></i>\n                <div style=\"font-size:12px; color:#94a3b8; line-height:1.3;\" data-kid=\"162\">Produto Viral</div>\n              </div>\n              <div style=\"padding:14px; border-radius:10px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.04); cursor:pointer;\" data-kid=\"163\">\n                <i class=\"ti ti-diamond\" style=\"font-size:20px; color:#94a3b8; display:block; margin-bottom:7px;\" data-kid=\"164\"></i>\n                <div style=\"font-size:12px; color:#94a3b8; line-height:1.3;\" data-kid=\"165\">Ticket Alto</div>\n              </div>\n              <div style=\"padding:14px; border-radius:10px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.04); cursor:pointer;\" data-kid=\"166\">\n                <i class=\"ti ti-percentage\" style=\"font-size:20px; color:#94a3b8; display:block; margin-bottom:7px;\" data-kid=\"167\"></i>\n                <div style=\"font-size:12px; color:#94a3b8; line-height:1.3;\" data-kid=\"168\">Comissão Alta</div>\n              </div>\n              <div style=\"padding:14px; border-radius:10px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.04); cursor:pointer;\" data-kid=\"169\">\n                <i class=\"ti ti-leaf\" style=\"font-size:20px; color:#94a3b8; display:block; margin-bottom:7px;\" data-kid=\"170\"></i>\n                <div style=\"font-size:12px; color:#94a3b8; line-height:1.3;\" data-kid=\"171\">Baixo Risco</div>\n              </div>\n            </div>\n          </div>\n\n          \n          <div style=\"display:flex; flex-direction:column; gap:28px;\" data-kid=\"172\">\n\n            \n            <div data-kid=\"173\">\n              <div style=\"display:flex; align-items:center; gap:10px; margin-bottom:14px;\" data-kid=\"174\">\n                <span style=\"font-size:10px; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; color:rgba(148,163,184,0.45); min-width:22px;\" data-kid=\"175\">05</span>\n                <span style=\"font-size:14px; font-weight:700; color:#f8fafc;\" data-kid=\"176\">Nível de experiência</span>\n              </div>\n              <div style=\"display:flex; gap:8px;\" data-kid=\"177\">\n                <div style=\"flex:1; padding:13px 10px; border-radius:10px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.04); cursor:pointer; text-align:center;\" data-kid=\"178\">\n                  <i class=\"ti ti-seedling\" style=\"font-size:20px; color:#94a3b8; display:block; margin-bottom:6px;\" data-kid=\"179\"></i>\n                  <div style=\"font-size:11px; color:#94a3b8;\" data-kid=\"180\">Iniciante</div>\n                </div>\n                \n                <div style=\"flex:1; padding:13px 10px; border-radius:10px; border:1px solid rgba(98,230,255,0.5); background:rgba(98,230,255,0.08); cursor:pointer; text-align:center; box-shadow:0 0 14px rgba(98,230,255,0.08);\" data-kid=\"181\">\n                  <i class=\"ti ti-trending-up\" style=\"font-size:20px; color:#62e6ff; display:block; margin-bottom:6px;\" data-kid=\"182\"></i>\n                  <div style=\"font-size:11px; font-weight:600; color:#62e6ff;\" data-kid=\"183\">Intermediário</div>\n                </div>\n                <div style=\"flex:1; padding:13px 10px; border-radius:10px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.04); cursor:pointer; text-align:center;\" data-kid=\"184\">\n                  <i class=\"ti ti-award\" style=\"font-size:20px; color:#94a3b8; display:block; margin-bottom:6px;\" data-kid=\"185\"></i>\n                  <div style=\"font-size:11px; color:#94a3b8;\" data-kid=\"186\">Avançado</div>\n                </div>\n              </div>\n            </div>\n\n            \n            <div data-kid=\"187\">\n              <div style=\"display:flex; align-items:center; gap:10px; margin-bottom:14px;\" data-kid=\"188\">\n                <span style=\"font-size:10px; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; color:rgba(148,163,184,0.45); min-width:22px;\" data-kid=\"189\">06</span>\n                <span style=\"font-size:14px; font-weight:700; color:#f8fafc;\" data-kid=\"190\">Tipo de tráfego</span>\n              </div>\n              <div style=\"display:flex; flex-wrap:wrap; gap:8px;\" data-kid=\"191\">\n                <span style=\"padding:7px 14px; border-radius:100px; font-size:12px; font-weight:600; border:1px solid rgba(98,230,255,0.55); background:rgba(98,230,255,0.1); color:#62e6ff; cursor:pointer; white-space:nowrap;\" data-kid=\"192\">Marketplace</span>\n                <span style=\"padding:7px 14px; border-radius:100px; font-size:12px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.04); color:#94a3b8; cursor:pointer; white-space:nowrap;\" data-kid=\"193\">Orgânico</span>\n                <span style=\"padding:7px 14px; border-radius:100px; font-size:12px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.04); color:#94a3b8; cursor:pointer; white-space:nowrap;\" data-kid=\"194\">Pago</span>\n                <span style=\"padding:7px 14px; border-radius:100px; font-size:12px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.04); color:#94a3b8; cursor:pointer; white-space:nowrap;\" data-kid=\"195\">Redes Sociais</span>\n                <span style=\"padding:7px 14px; border-radius:100px; font-size:12px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.04); color:#94a3b8; cursor:pointer; white-space:nowrap;\" data-kid=\"196\">Indefinido</span>\n              </div>\n            </div>\n\n            \n            <div data-kid=\"197\">\n              <div style=\"display:flex; align-items:center; gap:10px; margin-bottom:14px;\" data-kid=\"198\">\n                <span style=\"font-size:10px; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; color:rgba(148,163,184,0.45); min-width:22px;\" data-kid=\"199\">07</span>\n                <span style=\"font-size:14px; font-weight:700; color:#f8fafc;\" data-kid=\"200\">Investimento disponível</span>\n              </div>\n              <div style=\"padding:0 4px;\" data-kid=\"201\">\n                \n                <div style=\"position:relative; margin-bottom:14px; padding-top:10px;\" data-kid=\"202\">\n                  <div style=\"width:100%; height:3px; background:rgba(255,255,255,0.08); border-radius:100px;\" data-kid=\"203\">\n                    <div style=\"width:50%; height:100%; background:linear-gradient(90deg,#62e6ff,#65f0b7); border-radius:100px;\" data-kid=\"204\"></div>\n                  </div>\n                  <div style=\"position:absolute; left:0%; top:6px; width:10px; height:10px; border-radius:50%; background:rgba(255,255,255,0.2); margin-left:-5px;\" data-kid=\"205\"></div>\n                  <div style=\"position:absolute; left:25%; top:6px; width:10px; height:10px; border-radius:50%; background:rgba(255,255,255,0.2); margin-left:-5px;\" data-kid=\"206\"></div>\n                  <div style=\"position:absolute; left:50%; top:2px; width:16px; height:16px; border-radius:50%; background:#62e6ff; box-shadow:0 0 0 3px rgba(98,230,255,0.25), 0 0 16px rgba(98,230,255,0.5); margin-left:-8px; cursor:pointer;\" data-kid=\"207\"></div>\n                  <div style=\"position:absolute; left:75%; top:6px; width:10px; height:10px; border-radius:50%; background:rgba(255,255,255,0.1); margin-left:-5px;\" data-kid=\"208\"></div>\n                  <div style=\"position:absolute; right:0; top:6px; width:10px; height:10px; border-radius:50%; background:rgba(255,255,255,0.08); margin-right:-5px;\" data-kid=\"209\"></div>\n                </div>\n                <div style=\"display:flex; justify-content:space-between;\" data-kid=\"210\">\n                  <span style=\"font-size:10px; color:rgba(148,163,184,0.45);\" data-kid=\"211\">Sem estoque</span>\n                  <span style=\"font-size:10px; color:rgba(148,163,184,0.45);\" data-kid=\"212\">R$500</span>\n                  <span style=\"font-size:11px; font-weight:700; color:#62e6ff;\" data-kid=\"213\">R$500–2K</span>\n                  <span style=\"font-size:10px; color:rgba(148,163,184,0.45);\" data-kid=\"214\">R$2K–5K</span>\n                  <span style=\"font-size:10px; color:rgba(148,163,184,0.45);\" data-kid=\"215\">+R$5K</span>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <div style=\"height:1px; background:rgba(255,255,255,0.06); margin-bottom:28px;\" data-kid=\"216\"></div>\n\n        \n        <button style=\"width:100%; padding:18px 32px; border-radius:14px; border:none; background:linear-gradient(120deg,#62e6ff 0%,#65f0b7 45%,#62e6ff 100%); background-size:200% auto; color:#07090d; font-size:16px; font-weight:800; letter-spacing:-0.02em; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:10px; box-shadow:0 6px 40px rgba(98,230,255,0.28), 0 2px 0 rgba(255,255,255,0.12) inset; font-family:'Inter',sans-serif; position:relative; overflow:hidden; animation:shimmerBtn 3s linear infinite;\" data-kid=\"217\">\n          <div style=\"position:absolute; inset:0; background:linear-gradient(105deg,transparent 30%,rgba(255,255,255,0.22) 50%,transparent 70%); background-size:200% auto; animation:shimmerBtn 2.8s linear infinite;\" data-kid=\"218\"></div>\n          <i class=\"ti ti-sparkles\" style=\"font-size:20px; position:relative; z-index:1;\" data-kid=\"219\"></i>\n          <span style=\"position:relative; z-index:1;\" data-kid=\"220\">Encontrar Produtos</span>\n          <i class=\"ti ti-arrow-right\" style=\"font-size:18px; position:relative; z-index:1; margin-left:4px;\" data-kid=\"221\"></i>\n        </button>\n        <p style=\"text-align:center; font-size:11px; color:rgba(148,163,184,0.45); margin-top:13px; margin-bottom:0; display:flex; align-items:center; justify-content:center; gap:5px;\" data-kid=\"222\">\n          <i class=\"ti ti-lock\" style=\"font-size:12px;\" data-kid=\"223\"></i>\n          Dados usados apenas para gerar recomendações. Nunca compartilhados.\n        </p>\n\n      </div>\n    </div>\n  </main>\n</div>",
