ata-kid=\"302\">\n        <div class=\"stat-number shimmer-text\" data-kid=\"303\">12</div>\n        <div style=\"font-size: 14px; color: #94a3b8; margin-top: 8px; font-weight: 500;\" data-kid=\"304\">marketplaces analisados</div>\n      </div>\n      <div style=\"padding: 40px 32px; text-align: center; border-right: 1px solid rgba(255,255,255,0.07);\" data-kid=\"305\">\n        <div class=\"stat-number\" style=\"color: #62e6ff;\" data-kid=\"306\">200+</div>\n        <div style=\"font-size: 14px; color: #94a3b8; margin-top: 8px; font-weight: 500;\" data-kid=\"307\">categorias de produto</div>\n      </div>\n      <div style=\"padding: 40px 32px; text-align: center; border-right: 1px solid rgba(255,255,255,0.07);\" data-kid=\"308\">\n        <div class=\"stat-number\" style=\"color: #65f0b7;\" data-kid=\"309\">100%</div>\n        <div style=\"font-size: 14px; color: #94a3b8; margin-top: 8px; font-weight: 500;\" data-kid=\"310\">decisões baseadas em dados</div>\n      </div>\n      <div style=\"padding: 40px 32px; text-align: center;\" data-kid=\"311\">\n        <div class=\"stat-number\" style=\"color: #a78bfa;\" data-kid=\"312\">ML</div>\n        <div style=\"font-size: 14px; color: #94a3b8; margin-top: 8px; font-weight: 500;\" data-kid=\"313\">algoritmo sempre atualizado</div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section style=\"padding: 80px 40px 120px; position: relative; overflow: hidden;\" data-kid=\"314\">\n    <div style=\"position: absolute; inset: 0;\" data-kid=\"315\">\n      <div class=\"orb\" style=\"width: 500px; height: 500px; background: rgba(98,230,255,0.1); top: -100px; left: 50%; transform: translateX(-70%); animation: orbFloat1 16s ease-in-out infinite;\" data-kid=\"316\"></div>\n      <div class=\"orb\" style=\"width: 400px; height: 400px; background: rgba(139,92,246,0.1); bottom: 0; right: 10%; animation: orbFloat2 20s ease-in-out infinite;\" data-kid=\"317\"></div>\n    </div>\n    <div style=\"max-width: 860px; margin: 0 auto; position: relative; z-index: 5;\" data-kid=\"318\">\n      <div class=\"glass-strong electric-glow\" style=\"border-radius: 28px; padding: 80px 80px; text-align: center; border-color: rgba(98,230,255,0.18);\" data-kid=\"319\">\n        <div class=\"section-label\" style=\"margin-bottom: 20px;\" data-kid=\"320\">Comece agora</div>\n        <h2 style=\"font-size: 52px; font-weight: 800; letter-spacing: -0.04em; color: #f8fafc; margin: 0 0 20px; line-height: 1.05;\" data-kid=\"321\">Descubra o próximo produto<br data-kid=\"322\">vencedor para o seu perfil.</h2>\n        <p style=\"font-size: 17px; line-height: 1.65; color: #94a3b8; margin: 0 0 44px; max-width: 520px; margin-left: auto; margin-right: auto;\" data-kid=\"323\">Compare lucro, risco e conversão antes de apostar seu estoque. Tome decisões com dados, não com achismo.</p>\n        <div style=\"display: flex; flex-direction: column; align-items: center; gap: 14px;\" data-kid=\"324\">\n          <button class=\"electric-glow-btn\" style=\"padding: 16px 40px; background: linear-gradient(135deg, rgba(98,230,255,0.25), rgba(101,240,183,0.2)); border: 1px solid rgba(98,230,255,0.5); border-radius: 14px; color: #f8fafc; font-size: 17px; font-weight: 700; font-family: 'Inter', sans-serif; cursor: pointer; display: flex; align-items: center; gap: 10px; letter-spacing: -0.02em;\" data-kid=\"325\">\n            <i class=\"ti ti-sparkles\" style=\"font-size: 20px; color: #62e6ff;\" data-kid=\"326\"></i>\n            Começar análise gratuita\n          </button>\n          <p style=\"font-size: 13px; color: rgba(148,163,184,0.7); margin: 0;\" data-kid=\"327\">Sem cartão de crédito · Dados simulados no MVP</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <footer style=\"border-top: 1px solid rgba(255,255,255,0.08); padding: 48px 40px 40px;\" data-kid=\"328\">\n    <div style=\"max-width: 1200px; margin: 0 auto;\" data-kid=\"329\">\n      <div style=\"display: flex; align-items: flex-start; justify-content: 