      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  input[type=range] {\n    -webkit-appearance: none;\n    appearance: none;\n    height: 4px;\n    background: rgba(255,255,255,0.12);\n    border-radius: 9999px;\n    outline: none;\n  }\n  input[type=range]::-webkit-slider-thumb {\n    -webkit-appearance: none;\n    appearance: none;\n    width: 16px;\n    height: 16px;\n    border-radius: 50%;\n    background: #62e6ff;\n    cursor: pointer;\n    border: 2px solid #07090d;\n    box-shadow: 0 0 8px rgba(98,230,255,0.5);\n  }\n  input[type=number] {\n    -moz-appearance: textfield;\n  }\n  input[type=number]::-webkit-inner-spin-button,\n  input[type=number]::-webkit-outer-spin-button {\n    -webkit-appearance: none;\n  }\n</style>\n\n<div class=\"flex min-h-[950px] font-['Inter',sans-serif] text-[#f8fafc]\" style=\"background:#07090d;\" data-kid=\"1\">\n\n  \n  <aside class=\"w-16 shrink-0 flex flex-col items-center py-6 gap-6 border-r border-white/[0.08]\" style=\"background:rgba(255,255,255,0.03);\" data-kid=\"2\">\n    <div class=\"w-8 h-8 rounded-sm flex items-center justify-center\" style=\"background:linear-gradient(135deg,#62e6ff,#65f0b7);\" data-kid=\"3\">\n      <i class=\"ti ti-bolt text-[#07090d] text-sm font-bold\" data-kid=\"4\"></i>\n    </div>\n    <nav class=\"flex flex-col gap-3 mt-4\" data-kid=\"5\">\n      <button class=\"w-10 h-10 rounded-sm flex items-center justify-center text-[#94a3b8]\" style=\"background:rgba(255,255,255,0.04);\" data-kid=\"6\">\n        <i class=\"ti ti-layout-dashboard text-lg\" data-kid=\"7\"></i>\n      </button>\n      <button class=\"w-10 h-10 rounded-sm flex items-center justify-center text-[#94a3b8]\" style=\"background:rgba(255,255,255,0.04);\" data-kid=\"8\">\n        <i class=\"ti ti-shopping-bag text-lg\" data-kid=\"9\"></i>\n      </button>\n      <button class=\"w-10 h-10 rounded-sm flex items-center justify-center text-[#94a3b8]\" style=\"background:rgba(255,255,255,0.04);\" data-kid=\"10\">\n        <i class=\"ti ti-chart-bar text-lg\" data-kid=\"11\"></i>\n      </button>\n      <button class=\"w-10 h-10 rounded-sm flex items-center justify-center text-[#62e6ff]\" style=\"background:rgba(98,230,255,0.12); border:1px solid rgba(98,230,255,0.25);\" data-kid=\"12\">\n        <i class=\"ti ti-calculator text-lg\" data-kid=\"13\"></i>\n      </button>\n      <button class=\"w-10 h-10 rounded-sm flex items-center justify-center text-[#94a3b8]\" style=\"background:rgba(255,255,255,0.04);\" data-kid=\"14\">\n        <i class=\"ti ti-flask text-lg\" data-kid=\"15\"></i>\n      </button>\n    </nav>\n    <div class=\"mt-auto w-8 h-8 rounded-full overflow-hidden border border-white/20\" data-kid=\"16\">\n      <img src=\"https://i.pravatar.cc/32?u=vendor1\" decoding=\"async\" loading=\"lazy\" class=\"w-full h-full object-cover\" data-kid=\"17\">\n    </div>\n  </aside>\n\n  \n  <div class=\"flex-1 flex flex-col\" data-kid=\"18\">\n\n    \n    <header class=\"h-14 flex items-center justify-between px-8 border-b border-white/[0.08] shrink-0\" style=\"background:rgba(7,9,13,0.9); backdrop-filter:blur(16px);\" data-kid=\"19\">\n      <div class=\"flex items-center gap-3\" data-kid=\"20\">\n        <div class=\"w-8 h-8 rounded-lg flex items-center justify-center\" style=\"background:rgba(98,230,255,0.15); border:1px solid rgba(98,230,255,0.25);\" data-kid=\"21\">\n          <i class=\"ti ti-calculator text-sm\" style=\"color:#62e6ff;\" data-kid=\"22\"></i>\n        </div>\n        <div data-kid=\"23\">\n          <div class=\"text-sm font-semibold text-[#f8fafc]\" data-kid=\"24\">Simulador de Lucro</div>\n          <div class=\"text-xs text-[#94a3b8]\" data-kid=\"25\">Calcule sua margem real antes de apostar seu estoque</div>\n        </div>\n      </div>\n      <div class=\"flex items-center gap-3\" data-kid=\"26\">\n        <span class=\"text-xs px-3 py-1 rounded-full\" style=\"background:rgba(101,240,183,0.1); color:#65f0b7; border:1px solid rgba(101,240,183,0.2);\" data-kid=\"27\">\n          <i class=\"ti ti-sparkles text-xs mr-1\" data-kid=\"28\"></i>Mini Impressora Térmica\n        </span>\n      </div>\n    </header>\n\n    \n    <div class=\"flex-1 overflow-y-auto px-8 py-7\" style=\"background:radial-gradient(ellipse 70% 40% at 70% 20%, rgba(98,230,255,0.05) 0%, transparent 60%);\" data-kid=\"29\">\n\n      <div class=\"grid grid-cols-2 gap-7 max-w-[1200px] mx-auto\" data-kid=\"30\">\n\n        \n        <div class=\"rounded-xl p-7 flex flex-col gap-7\" style=\"background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.12); backdrop-filter:blur(16px);\" data-kid=\"31\">\n\n          \n          <div data-kid=\"32\">\n            <div class=\"text-xs font-semibold tracking-widest text-[#94a3b8] uppercase mb-4 flex items-center gap-2\" data-kid=\"33\">\n              <i class=\"ti ti-tag text-xs\" data-kid=\"34\"></i> Preço e Custo\n            </div>\n            <div class=\"space-y-4\" data-kid=\"35\">\n              <div class=\"flex flex-col gap-1.5\" data-kid=\"36\">\n                <label class=\"text-xs text-[#94a3b8]\" data-kid=\"37\">Preço de Venda</label>\n                <div class=\"flex items-center gap-2 px-4 py-3 rounded-lg\" style=\"background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.14);\" data-kid=\"38\">\n                  <span class=\"text-sm text-[#94a3b8]\" data-kid=\"39\">R$</span>\n                  <input type=\"number\" value=\"89\" class=\"flex-1 bg-transparent text-[#f8fafc] text-sm font-medium outline-none\" style=\"font-family:'JetBrains Mono',monospace;\" data-kid=\"40\">\n                </div>\n              </div>\n              <div class=\"flex flex-col gap-1.5\" data-kid=\"41\">\n                <label class=\"text-xs text-[#94a3b8]\" data-kid=\"42\">Custo do Produto</label>\n                <div class=\"flex items-center gap-2 px-4 py-3 rounded-lg\" style=\"background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.14);\" data-kid=\"43\">\n                  <span class=\"text-sm text-[#94a3b8]\" data-kid=\"44\">R$</span>\n                  <input type=\"number\" value=\"45\" class=\"flex-1 bg-transparent text-[#f8fafc] text-sm font-medium outline-none\" style=\"font-family:'JetBrains Mono',monospace;\" data-kid=\"45\">\n                </div>\n              </div>\n            </div>\n          </div>\n\n          \n          <div data-kid=\"46\">\n            <div class=\"text-xs font-semibold tracking-widest text-[#94a3b8] uppercase mb-4 flex items-center gap-2\" data-kid=\"47\">\n              <i class=\"ti ti-percentage text-xs\" data-kid=\"48\"></i> Taxas da Plataforma\n            </div>\n            <div class=\"space-y-5\" data-kid=\"49\">\n              <div data-kid=\"50\">\n                <div class=\"flex justify-between items-center mb-2\" data-kid=\"51\">\n                  <label class=\"text-xs text-[#94a3b8]\" data-kid=\"52\">Taxa Shopee</label>\n                  <span class=\"text-sm font-semibold\" style=\"font-family:'JetBrains Mono',monospace; color:#62e6ff;\" data-kid=\"53\">14%</span>\n                </div>\n                <input type=\"range\" min=\"0\" max=\"20\" value=\"14\" class=\"w-full\" data-kid=\"54\">\n                <div class=\"flex justify-between text-xs text-[#94a3b8] mt-1\" data-kid=\"55\"><span data-kid=\"56\">0%</span><span data-kid=\"57\">20%</span></div>\n              </div>\n              <div class=\"grid grid-cols-2 gap-3\" data-kid=\"58\">\n                <div class=\"flex flex-col gap-1.5\" data-kid=\"59\">\n                  <label class=\"text-xs text-[#94a3b8]\" data-kid=\"60\">Frete estimado</label>\n                  <div class=\"flex items-center gap-2 px-3 py-2.5 rounded-lg\" style=\"background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.14);\" data-kid=\"61\">\n                    <span class=\"text-xs text-[#94a3b8]\" data-kid=\"62\">R$</span>\n                    <input type=\"number\" value=\"12\" class=\"flex-1 bg-transparent text-[#f8fafc] text-sm outline-none\" style=\"font-family:'JetBrains Mono',monospace;\" data-kid=\"63\">\n                  </div>\n                </div>\n                <div class=\"flex flex-col gap-1.5\" data-kid=\"64\">\n                  <label class=\"text-xs text-[#94a3b8]\" data-kid=\"65\">Embalagem</label>\n                  <div class=\"flex items-center gap-2 px-3 py-2.5 rounded-lg\" style=\"background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.14);\" data-kid=\"66\">\n                    <span class=\"text-xs text-[#94a3b8]\" data-kid=\"67\">R$</span>\n                    <input type=\"number\" value=\"2.50\" class=\"flex-1 bg-transparent text-[#f8fafc] text-sm outline-none\" style=\"font-family:'JetBrains Mono',monospace;\" data-kid=\"68\">\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n\n          \n          <div data-kid=\"69\">\n            <div class=\"text-xs font-semibold tracking-widest text-[#94a3b8] uppercase mb-4 flex items-center gap-2\" data-kid=\"70\">\n              <i class=\"ti ti-receipt text-xs\" data-kid=\"71\"></i> Impostos e Comissões\n            </div>\n            <div class=\"space-y-4\" data-kid=\"72\">\n              <div data-kid=\"73\">\n                <div class=\"flex justify-between items-center mb-2\" data-kid=\"74\">\n                  <label class=\"text-xs text-[#94a3b8]\" data-kid=\"75\">Imposto (Simples)</label>\n                  <span class=\"text-sm font-semibold\" style=\"font-family:'JetBrains Mono',monospace; color:#f8b85c;\" data-kid=\"76\">6%</span>\n                </div>\n                <input type=\"range\" min=\"0\" max=\"15\" value=\"6\" class=\"w-full\" data-kid=\"77\">\n                <div class=\"flex justify-between text-xs text-[#94a3b8] mt-1\" data-kid=\"78\"><span data-kid=\"79\">0%</span><span data-kid=\"80\">15%</span></div>\n              </div>\n              <div class=\"flex flex-col gap-1.5\" data-kid=\"81\">\n                <label class=\"text-xs text-[#94a3b8]\" data-kid=\"82\">Comissão de Afiliado</label>\n                <div class=\"flex items-center gap-2 px-3 py-2.5 rounded-lg\" style=\"background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.14);\" data-kid=\"83\">\n                  <input type=\"number\" value=\"0\" class=\"flex-1 bg-transparent text-[#94a3b8] text-sm outline-none\" style=\"font-family:'JetBrains Mono',monospace;\" data-kid=\"84\">\n                  <span class=\"text-xs text-[#94a3b8]\" data-kid=\"85\">%</span>\n                </div>\n              </div>\n            </div>\n          </div>\n\n          \n          <div data-kid=\"86\">\n            <div class=\"text-xs font-semibold tracking-widest text-[#94a3b8] uppercase mb-4 flex items-center gap-2\" data-kid=\"87\">\n              <i class=\"ti ti-stack text-xs\" data-kid=\"88\"></i> Volume de Vendas\n            </div>\n            <div data-kid=\"89\">\n              <div class=\"flex justify-between items-center mb-2\" data-kid=\"90\">\n                <label class=\"text-xs text-[#94a3b8]\" data-kid=\"91\">Vendas/mês esperadas</label>\n                <span class=\"text-sm font-semibold text-[#f8fafc]\" style=\"font-family:'JetBrains Mono',monospace;\" data-kid=\"92\">50 und.</span>\n              </div>\n              <input type=\"range\" min=\"10\" max=\"500\" value=\"50\" class=\"w-full\" data-kid=\"93\">\n              <div class=\"flex justify-between text-xs text-[#94a3b8] mt-1\" data-kid=\"94\"><span data-kid=\"95\">10</span><span data-kid=\"96\">500</span></div>\n            </div>\n          </div>\n\n          \n          <button class=\"w-full py-3.5 rounded-lg text-sm font-semibold text-[#07090d] flex items-center justify-center gap-2 transition-all\" style=\"background:linear-gradient(135deg,#62e6ff,#65f0b7); box-shadow:0 0 24px rgba(98,230,255,0.25);\" data-kid=\"97\">\n            <i class=\"ti ti-calculator text-sm\" data-kid=\"98\"></i>\n            Calcular Lucro\n          </button>\n\n        </div>\n\n        \n        <div class=\"flex flex-col gap-5\" data-kid=\"99\">\n\n          \n          <div class=\"rounded-xl p-7\" style=\"background:rgba(101,240,183,0.07); border:1px solid rgba(101,240,183,0.2); backdrop-filter:blur(16px); box-shadow:0 0 48px rgba(98,230,255,0.06);\" data-kid=\"100\">\n            <div class=\"text-xs font-semibold tracking-widest text-[#94a3b8] uppercase mb-3\" data-kid=\"101\">Lucro Mensal Estimado</div>\n            <div class=\"text-6xl font-bold leading-none mb-1\" style=\"color:#65f0b7; font-family:'JetBrains Mono',monospace;\" data-kid=\"102\">R$&nbsp;1.174</div>\n            <div class=\"text-sm text-[#94a3b8]\" data-kid=\"103\">com 50 unidades vendidas/mês</div>\n\n            \n            <div class=\"mt-6 space-y-2.5\" data-kid=\"104\">\n              <div class=\"flex items-center justify-between py-2.5 border-b border-white/[0.08]\" data-kid=\"105\">\n                <span class=\"text-sm text-[#94a3b8]\" data-kid=\"106\">Receita Total</span>\n                <span class=\"text-sm font-medium text-[#f8fafc]\" style=\"font-family:'JetBrains Mono',monospace;\" data-kid=\"107\">R$ 4.450,00</span>\n              </div>\n              <div class=\"flex items-center justify-between py-2.5 border-b border-white/[0.08]\" data-kid=\"108\">\n                <span class=\"text-sm text-[#94a3b8]\" data-kid=\"109\">(-) Custo dos Produtos</span>\n                <span class=\"text-sm font-medium\" style=\"color:#ef4444; font-family:'JetBrains Mono',monospace;\" data-kid=\"110\">- R$ 2.250,00</span>\n              </div>\n              <div class=\"flex items-center justify-between py-2.5 border-b border-white/[0.08]\" data-kid=\"111\">\n                <span class=\"text-sm text-[#94a3b8]\" data-kid=\"112\">(-) Taxas da Plataforma</span>\n                <span class=\"text-sm font-medium\" style=\"color:#ef4444; font-family:'JetBrains Mono',monospace;\" data-kid=\"113\">- R$ 623,00</span>\n              </div>\n              <div class=\"flex items-center justify-between py-2.5 border-b border-white/[0.08]\" data-kid=\"114\">\n                <span class=\"text-sm text-[#94a3b8]\" data-kid=\"115\">(-) Frete + Embalagem</span>\n                <span class=\"text-sm font-medium\" style=\"color:#ef4444; font-family:'JetBrains Mono',monospace;\" data-kid=\"116\">- R$ 725,00</span>\n              </div>\n              <div class=\"flex items-center justify-between py-2.5 border-b border-white/[0.08]\" data-kid=\"117\">\n                <span class=\"text-sm text-[#94a3b8]\" data-kid=\"118\">(-) Impostos</span>\n                <span class=\"text-sm font-medium\" style=\"color:#ef4444; font-family:'JetBrains Mono',monospace;\" data-kid=\"119\">- R$ 267,00</span>\n              </div>\n              <div class=\"flex items-center justify-between py-2.5 bg-white/[0.03] px-3 rounded-lg mt-2\" data-kid=\"120\">\n                <span class=\"text-sm font-semibold text-[#f8fafc]\" data-kid=\"121\">(=) Lucro Líquido</span>\n                <span class=\"text-sm font-bold\" style=\"color:#65f0b7; font-family:'JetBrains Mono',monospace;\" data-kid=\"122\">R$ 1.174,00</span>\n              </div>\n            </div>\n\n            \n            <div class=\"mt-5\" data-kid=\"123\">\n              <div class=\"flex justify-between text-xs mb-2\" data-kid=\"124\">\n                <span class=\"text-[#94a3b8]\" data-kid=\"125\">Margem Líquida</span>\n                <span class=\"font-semibold\" style=\"color:#65f0b7; font-family:'JetBrains Mono',monospace;\" data-kid=\"126\">26.4%</span>\n              </div>\n              <div class=\"h-2 rounded-full w-full\" style=\"background:rgba(255,255,255,0.08);\" data-kid=\"127\">\n                <div class=\"h-2 rounded-full\" style=\"width:26.4%; background:linear-gradient(90deg,#62e6ff,#65f0b7);\" data-kid=\"128\"></div>\n              </div>\n            </div>\n\n            \n            <div class=\"mt-4 flex items-center gap-2 text-sm\" data-kid=\"129\">\n              <i class=\"ti ti-target text-xs\" style=\"color:#62e6ff;\" data-kid=\"130\"></i>\n              <span class=\"text-[#94a3b8]\" data-kid=\"131\">Ponto de Equilíbrio:</span>\n              <span class=\"font-semibold text-[#f8fafc]\" style=\"font-family:'JetBrains Mono',monospace;\" data-kid=\"132\">19 unidades/mês</span>\n            </div>\n          </div>\n\n          \n          <div class=\"rounded-xl p-6\" style=\"background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.1);\" data-kid=\"133\">\n            <div class=\"text-xs font-semibold tracking-widest text-[#94a3b8] uppercase mb-4\" data-kid=\"134\">Comparativo por Escala</div>\n            <canvas id=\"profitChart\" height=\"160\" data-kid=\"135\"></canvas>\n          </div>\n\n          \n          <div class=\"rounded-xl p-5 flex items-start gap-3\" style=\"background:rgba(101,240,183,0.07); border:1px solid rgba(101,240,183,0.25);\" data-kid=\"136\">\n            <div class=\"w-7 h-7 rounded-lg flex items-center justify-center shrink-0 mt-0.5\" style=\"background:rgba(101,240,183,0.2);\" data-kid=\"137\">\n              <i class=\"ti ti-check text-sm\" style=\"color:#65f0b7;\" data-kid=\"138\"></i>\n            </div>\n            <div data-kid=\"139\">\n              <div class=\"text-sm font-semibold mb-1\" style=\"color:#65f0b7;\" data-kid=\"140\">Boa margem detectada</div>\n              <div class=\"text-xs text-[#94a3b8]\" data-kid=\"141\">Considere aumentar o volume para <strong class=\"text-[#f8fafc]\" data-kid=\"142\">100–150 unidades/mês</strong> para atingir R$2.000+ de lucro mensal com a mesma estrutura de custos.</div>\n            </div>\n          </div>\n\n        </div>\n\n      </div>\n    </div>\n  </div>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/chart.js\" data-kid=\"143\"></script>\n<script data-kid=\"144\">\n  const ctx = document.getElementById('profitChart').getContext('2d');\n  new Chart(ctx, {\n    type: 'bar',\n    data: {\n      labels: ['10 und', '25 und', '50 und', '100 und', '200 und'],\n      datasets: [\n        {\n          label: 'Receita',\n          data: [890, 2225, 4450, 8900, 17800],\n          backgroundColor: 'rgba(98,230,255,0.25)',\n          borderColor: '#62e6ff',\n          borderWidth: 1,\n          borderRadius: 4\n        },\n        {\n          label: 'Custo Total',\n          data: [657, 1643, 3276, 6552, 13104],\n          backgroundColor: 'rgba(248,184,92,0.2)',\n          borderColor: '#f8b85c',\n          borderWidth: 1,\n          borderRadius: 4\n        },\n        {\n          label: 'Lucro',\n          data: [235, 587, 1174, 2348, 4696],\n          backgroundColor: 'rgba(101,240,183,0.3)',\n          borderColor: '#65f0b7',\n          borderWidth: 1,\n          borderRadius: 4\n        }\n      ]\n    },\n    options: {\n      responsive: true,\n      maintainAspectRatio: false,\n      plugins: {\n        legend: {\n          labels: { color: '#94a3b8', font: { size: 11 }, boxWidth: 10 }\n        }\n      },\n      scales: {\n        x: {\n          grid: { color: 'rgba(255,255,255,0.05)' },\n          ticks: { color: '#94a3b8', font: { size: 10 } }\n        },\n        y: {\n          grid: { color: 'rgba(255,255,255,0.05)' },\n          ticks: { color: '#94a3b8', font: { size: 10 },\n            callback: v => 'R$' + (v/1000).toFixed(0) + 'k'\n          }\n        }\n      }\n    }\n  });\n</script>\n",
