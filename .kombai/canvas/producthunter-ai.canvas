      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n</style>\n<script src=\"https://cdn.jsdelivr.net/npm/chart.js\" data-kid=\"1\"></script>\n\n<div class=\"flex min-h-[5000px]\" style=\"background:#07090d; font-family:'Inter',sans-serif; color:#f8fafc;\" data-kid=\"2\">\n\n  \n  <div class=\"absolute inset-0 overflow-hidden pointer-events-none\" style=\"z-index:0;\" data-kid=\"3\">\n    <div class=\"absolute\" style=\"width:600px;height:600px;top:-100px;left:200px;background:radial-gradient(circle,rgba(139,92,246,0.08) 0%,transparent 70%);border-radius:50%;\" data-kid=\"4\"></div>\n    <div class=\"absolute\" style=\"width:500px;height:500px;top:400px;right:100px;background:radial-gradient(circle,rgba(98,230,255,0.06) 0%,transparent 70%);border-radius:50%;\" data-kid=\"5\"></div>\n    <div class=\"absolute\" style=\"width:400px;height:400px;bottom:200px;left:400px;background:radial-gradient(circle,rgba(101,240,183,0.05) 0%,transparent 70%);border-radius:50%;\" data-kid=\"6\"></div>\n  </div>\n\n  \n  <div class=\"relative flex flex-col items-center py-8 gap-6\" style=\"z-index:10;width:72px;min-height:100%;background:rgba(255,255,255,0.03);border-right:1px solid rgba(255,255,255,0.08);flex-shrink:0;\" data-kid=\"7\">\n    \n    <div class=\"flex items-center justify-center w-10 h-10 rounded-xl\" style=\"background:linear-gradient(135deg,#62e6ff22,#8b5cf622);border:1px solid rgba(98,230,255,0.3);\" data-kid=\"8\">\n      <i class=\"ti ti-target\" style=\"color:#62e6ff;font-size:18px;\" data-kid=\"9\"></i>\n    </div>\n    <div class=\"w-8\" style=\"height:1px;background:rgba(255,255,255,0.08);\" data-kid=\"10\"></div>\n    \n    <div class=\"flex flex-col gap-4\" data-kid=\"11\">\n      <div class=\"flex items-center justify-center w-10 h-10 rounded-xl cursor-pointer\" style=\"color:#94a3b8;\" title=\"Dashboard\" data-kid=\"12\">\n        <i class=\"ti ti-layout-dashboard\" style=\"font-size:18px;\" data-kid=\"13\"></i>\n      </div>\n      <div class=\"flex items-center justify-center w-10 h-10 rounded-xl cursor-pointer\" style=\"color:#94a3b8;\" title=\"Buscar\" data-kid=\"14\">\n        <i class=\"ti ti-search\" style=\"font-size:18px;\" data-kid=\"15\"></i>\n      </div>\n      <div class=\"flex items-center justify-center w-10 h-10 rounded-xl cursor-pointer\" style=\"color:#94a3b8;\" title=\"Recomendações\" data-kid=\"16\">\n        <i class=\"ti ti-sparkles\" style=\"font-size:18px;\" data-kid=\"17\"></i>\n      </div>\n      <div class=\"flex items-center justify-center w-10 h-10 rounded-xl cursor-pointer\" style=\"color:#94a3b8;\" title=\"Simulador\" data-kid=\"18\">\n        <i class=\"ti ti-calculator\" style=\"font-size:18px;\" data-kid=\"19\"></i>\n      </div>\n      <div class=\"flex items-center justify-center w-10 h-10 rounded-xl cursor-pointer\" style=\"background:rgba(139,92,246,0.15);border:1px solid rgba(139,92,246,0.4);\" title=\"AI Lab\" data-kid=\"20\">\n        <i class=\"ti ti-flask\" style=\"color:#8b5cf6;font-size:18px;\" data-kid=\"21\"></i>\n      </div>\n    </div>\n    <div class=\"mt-auto flex flex-col gap-3 items-center\" data-kid=\"22\">\n      <div class=\"w-8 h-8 rounded-full overflow-hidden\" style=\"border:1px solid rgba(255,255,255,0.15);\" data-kid=\"23\">\n        <img src=\"https://i.pravatar.cc/32?u=ailab\" decoding=\"async\" loading=\"lazy\" class=\"w-full h-full object-cover\" data-kid=\"24\">\n      </div>\n    </div>\n  </div>\n\n  \n  <div class=\"flex-1 flex flex-col relative\" style=\"z-index:5;\" data-kid=\"25\">\n\n    \n    <div class=\"flex items-center justify-between px-10 py-5\" style=\"border-bottom:1px solid rgba(255,255,255,0.07);background:rgba(7,9,13,0.8);backdrop-filter:blur(20px);\" data-kid=\"26\">\n      <div class=\"flex items-center gap-4\" data-kid=\"27\">\n        <div class=\"flex items-center justify-center w-10 h-10 rounded-xl\" style=\"background:rgba(139,92,246,0.15);border:1px solid rgba(139,92,246,0.3);\" data-kid=\"28\">\n          <i class=\"ti ti-flask\" style=\"color:#8b5cf6;font-size:20px;\" data-kid=\"29\"></i>\n        </div>\n        <div data-kid=\"30\">\n          <h1 class=\"text-xl font-bold tracking-tight\" style=\"color:#f8fafc;line-height:1.2;\" data-kid=\"31\">Laboratório de IA</h1>\n          <p class=\"text-xs font-medium\" style=\"color:#94a3b8;\" data-kid=\"32\">Entenda como o ProductHunter AI calcula scores e recomendações.</p>\n        </div>\n      </div>\n      <div class=\"flex items-center gap-3\" data-kid=\"33\">\n        <div class=\"flex items-center gap-2 px-3 py-1.5 rounded-full\" style=\"background:rgba(101,240,183,0.1);border:1px solid rgba(101,240,183,0.25);\" data-kid=\"34\">\n          <div class=\"w-1.5 h-1.5 rounded-full\" style=\"background:#65f0b7;box-shadow:0 0 6px #65f0b7;\" data-kid=\"35\"></div>\n          <span class=\"text-xs font-medium\" style=\"color:#65f0b7;\" data-kid=\"36\">Modelo v2.3.1 ativo</span>\n        </div>\n        <div class=\"px-3 py-1.5 rounded-full text-xs font-medium\" style=\"background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.12);color:#94a3b8;\" data-kid=\"37\">\n          Última atualização: Hoje\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"flex flex-col gap-10 px-10 py-10\" data-kid=\"38\">\n\n      \n      <div class=\"rounded-2xl p-8\" style=\"background:rgba(139,92,246,0.06);border:1px solid rgba(139,92,246,0.2);\" data-kid=\"39\">\n        <div class=\"flex items-center gap-3 mb-8\" data-kid=\"40\">\n          <div class=\"flex items-center justify-center w-8 h-8 rounded-lg\" style=\"background:rgba(139,92,246,0.2);border:1px solid rgba(139,92,246,0.4);\" data-kid=\"41\">\n            <i class=\"ti ti-brain\" style=\"color:#8b5cf6;font-size:16px;\" data-kid=\"42\"></i>\n          </div>\n          <div data-kid=\"43\">\n            <h2 class=\"text-lg font-bold\" style=\"color:#f8fafc;\" data-kid=\"44\">Da Regra ao Machine Learning</h2>\n            <p class=\"text-sm\" style=\"color:#94a3b8;\" data-kid=\"45\">Como evoluímos de regras fixas para inteligência adaptativa</p>\n          </div>\n        </div>\n\n        <div class=\"grid gap-6\" style=\"grid-template-columns:1fr 1fr;\" data-kid=\"46\">\n          \n          <div class=\"rounded-xl p-6\" style=\"background:rgba(248,184,92,0.06);border:1px solid rgba(248,184,92,0.25);\" data-kid=\"47\">\n            <div class=\"flex items-center gap-3 mb-5\" data-kid=\"48\">\n              <div class=\"px-2.5 py-1 rounded-full text-xs font-bold uppercase tracking-widest\" style=\"background:rgba(248,184,92,0.15);color:#f8b85c;border:1px solid rgba(248,184,92,0.3);\" data-kid=\"49\">Antes</div>\n              <span class=\"text-sm font-semibold\" style=\"color:#f8b85c;\" data-kid=\"50\">Regras Manuais</span>\n            </div>\n            <div class=\"rounded-lg p-4 mb-5 font-mono text-sm\" style=\"background:rgba(0,0,0,0.4);border:1px solid rgba(255,255,255,0.08);color:#f8b85c;line-height:1.8;\" data-kid=\"51\">\n              <span style=\"color:#94a3b8;\" data-kid=\"52\">// Lógica simplificada</span><br data-kid=\"53\">\n              <span style=\"color:#62e6ff;\" data-kid=\"54\">if</span> (margem &gt; 30% <span style=\"color:#62e6ff;\" data-kid=\"55\">&amp;&amp;</span><br data-kid=\"56\">\n              &nbsp;&nbsp;&nbsp;concorrencia &lt; 50) {<br data-kid=\"57\">\n              &nbsp;&nbsp;<span style=\"color:#65f0b7;\" data-kid=\"58\">return</span> \"bom_produto\";<br data-kid=\"59\">\n              }\n            </div>\n            <ul class=\"flex flex-col gap-2.5\" data-kid=\"60\">\n              <li class=\"flex items-center gap-2.5 text-sm\" style=\"color:#94a3b8;\" data-kid=\"61\">\n                <i class=\"ti ti-x\" style=\"color:#ef4444;font-size:14px;flex-shrink:0;\" data-kid=\"62\"></i>\n                Considera apenas 2 variáveis\n              </li>\n              <li class=\"flex items-center gap-2.5 text-sm\" style=\"color:#94a3b8;\" data-kid=\"63\">\n                <i class=\"ti ti-x\" style=\"color:#ef4444;font-size:14px;flex-shrink:0;\" data-kid=\"64\"></i>\n                Regras rígidas, não se adaptam\n              </li>\n              <li class=\"flex items-center gap-2.5 text-sm\" style=\"color:#94a3b8;\" data-kid=\"65\">\n                <i class=\"ti ti-x\" style=\"color:#ef4444;font-size:14px;flex-shrink:0;\" data-kid=\"66\"></i>\n                Ignora sazonalidade e tendências\n              </li>\n              <li class=\"flex items-center gap-2.5 text-sm\" style=\"color:#94a3b8;\" data-kid=\"67\">\n                <i class=\"ti ti-x\" style=\"color:#ef4444;font-size:14px;flex-shrink:0;\" data-kid=\"68\"></i>\n                Erros frequentes em nichos novos\n              </li>\n            </ul>\n          </div>\n\n          \n          <div class=\"rounded-xl p-6 relative overflow-hidden\" style=\"background:rgba(101,240,183,0.06);border:1px solid rgba(101,240,183,0.25);\" data-kid=\"69\">\n            <div class=\"absolute top-0 right-0 w-40 h-40 pointer-events-none\" style=\"background:radial-gradient(circle,rgba(101,240,183,0.08) 0%,transparent 70%);\" data-kid=\"70\"></div>\n            <div class=\"flex items-center gap-3 mb-5\" data-kid=\"71\">\n              <div class=\"px-2.5 py-1 rounded-full text-xs font-bold uppercase tracking-widest\" style=\"background:rgba(101,240,183,0.15);color:#65f0b7;border:1px solid rgba(101,240,183,0.3);\" data-kid=\"72\">Agora</div>\n              <span class=\"text-sm font-semibold\" style=\"color:#65f0b7;\" data-kid=\"73\">Machine Learning</span>\n              <div class=\"ml-auto px-2 py-0.5 rounded-full text-xs font-bold\" style=\"background:rgba(101,240,183,0.2);color:#65f0b7;\" data-kid=\"74\">Ativo</div>\n            </div>\n            <div class=\"rounded-lg p-4 mb-5 text-sm\" style=\"background:rgba(0,0,0,0.4);border:1px solid rgba(101,240,183,0.15);line-height:1.8;color:#94a3b8;\" data-kid=\"75\">\n              O modelo aprende padrões de <span style=\"color:#65f0b7;font-weight:600;\" data-kid=\"76\">1.200+ produtos</span>, considera <span style=\"color:#62e6ff;font-weight:600;\" data-kid=\"77\">12 variáveis simultâneas</span> e se atualiza automaticamente com novos dados de mercado.\n            </div>\n            <ul class=\"flex flex-col gap-2.5\" data-kid=\"78\">\n              <li class=\"flex items-center gap-2.5 text-sm\" style=\"color:#f8fafc;\" data-kid=\"79\">\n                <i class=\"ti ti-check\" style=\"color:#65f0b7;font-size:14px;flex-shrink:0;\" data-kid=\"80\"></i>\n                12 variáveis processadas em paralelo\n              </li>\n              <li class=\"flex items-center gap-2.5 text-sm\" style=\"color:#f8fafc;\" data-kid=\"81\">\n                <i class=\"ti ti-check\" style=\"color:#65f0b7;font-size:14px;flex-shrink:0;\" data-kid=\"82\"></i>\n                Aprende com novos padrões de mercado\n              </li>\n              <li class=\"flex items-center gap-2.5 text-sm\" style=\"color:#f8fafc;\" data-kid=\"83\">\n                <i class=\"ti ti-check\" style=\"color:#65f0b7;font-size:14px;flex-shrink:0;\" data-kid=\"84\"></i>\n                Sazonalidade e tendências incluídas\n              </li>\n              <li class=\"flex items-center gap-2.5 text-sm\" style=\"color:#f8fafc;\" data-kid=\"85\">\n                <i class=\"ti ti-check\" style=\"color:#65f0b7;font-size:14px;flex-shrink:0;\" data-kid=\"86\"></i>\n                Accuracy de 87.3% nos testes\n              </li>\n            </ul>\n          </div>\n        </div>\n      </div>\n\n      \n      <div data-kid=\"87\">\n        <div class=\"flex items-center justify-between mb-6\" data-kid=\"88\">\n          <div data-kid=\"89\">\n            <h2 class=\"text-lg font-bold\" style=\"color:#f8fafc;\" data-kid=\"90\">Features do Modelo</h2>\n            <p class=\"text-sm\" style=\"color:#94a3b8;\" data-kid=\"91\">Dados utilizados para calcular o score de oportunidade</p>\n          </div>\n          <div class=\"flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-medium\" style=\"background:rgba(98,230,255,0.1);border:1px solid rgba(98,230,255,0.25);color:#62e6ff;\" data-kid=\"92\">\n            <i class=\"ti ti-database\" style=\"font-size:12px;\" data-kid=\"93\"></i>\n            12 variáveis ativas\n          </div>\n        </div>\n\n        <div class=\"grid gap-4\" style=\"grid-template-columns:repeat(4,1fr);\" data-kid=\"94\">\n          \n          <div class=\"rounded-xl p-5\" style=\"background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.09);\" data-kid=\"95\">\n            <div class=\"flex items-center gap-3 mb-3\" data-kid=\"96\">\n              <div class=\"flex items-center justify-center w-8 h-8 rounded-lg\" style=\"background:rgba(98,230,255,0.12);border:1px solid rgba(98,230,255,0.2);\" data-kid=\"97\">\n                <i class=\"ti ti-coins\" style=\"color:#62e6ff;font-size:15px;\" data-kid=\"98\"></i>\n              </div>\n              <span class=\"text-sm font-semibold\" style=\"color:#f8fafc;\" data-kid=\"99\">Margem Bruta</span>\n            </div>\n            <p class=\"text-xs mb-3\" style=\"color:#94a3b8;\" data-kid=\"100\">Percentual de lucro sobre o preço de venda</p>\n            <div class=\"flex items-center gap-2\" data-kid=\"101\">\n              <div class=\"flex-1 h-1.5 rounded-full\" style=\"background:rgba(255,255,255,0.08);\" data-kid=\"102\">\n                <div class=\"h-full rounded-full\" style=\"width:92%;background:linear-gradient(90deg,#65f0b7,#62e6ff);\" data-kid=\"103\"></div>\n              </div>\n              <span class=\"text-xs font-bold\" style=\"color:#65f0b7;\" data-kid=\"104\">Alta</span>\n            </div>\n          </div>\n\n          \n          <div class=\"rounded-xl p-5\" style=\"background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.09);\" data-kid=\"105\">\n            <div class=\"flex items-center gap-3 mb-3\" data-kid=\"106\">\n              <div class=\"flex items-center justify-center w-8 h-8 rounded-lg\" style=\"background:rgba(98,230,255,0.12);border:1px solid rgba(98,230,255,0.2);\" data-kid=\"107\">\n                <i class=\"ti ti-users\" style=\"color:#62e6ff;font-size:15px;\" data-kid=\"108\"></i>\n              </div>\n              <span class=\"text-sm font-semibold\" style=\"color:#f8fafc;\" data-kid=\"109\">Concorrência</span>\n            </div>\n            <p class=\"text-xs mb-3\" style=\"color:#94a3b8;\" data-kid=\"110\">Número de vendedores no mesmo nicho</p>\n            <div class=\"flex items-center gap-2\" data-kid=\"111\">\n              <div class=\"flex-1 h-1.5 rounded-full\" style=\"background:rgba(255,255,255,0.08);\" data-kid=\"112\">\n                <div class=\"h-full rounded-full\" style=\"width:75%;background:linear-gradient(90deg,#65f0b7,#62e6ff);\" data-kid=\"113\"></div>\n              </div>\n              <span class=\"text-xs font-bold\" style=\"color:#65f0b7;\" data-kid=\"114\">Alta</span>\n            </div>\n          </div>\n\n          \n          <div class=\"rounded-xl p-5\" style=\"background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.09);\" data-kid=\"115\">\n            <div class=\"flex items-center gap-3 mb-3\" data-kid=\"116\">\n              <div class=\"flex items-center justify-center w-8 h-8 rounded-lg\" style=\"background:rgba(98,230,255,0.12);border:1px solid rgba(98,230,255,0.2);\" data-kid=\"117\">\n                <i class=\"ti ti-trending-up\" style=\"color:#62e6ff;font-size:15px;\" data-kid=\"118\"></i>\n              </div>\n              <span class=\"text-sm font-semibold\" style=\"color:#f8fafc;\" data-kid=\"119\">Tendência</span>\n            </div>\n            <p class=\"text-xs mb-3\" style=\"color:#94a3b8;\" data-kid=\"120\">Crescimento de demanda nos últimos 90 dias</p>\n            <div class=\"flex items-center gap-2\" data-kid=\"121\">\n              <div class=\"flex-1 h-1.5 rounded-full\" style=\"background:rgba(255,255,255,0.08);\" data-kid=\"122\">\n                <div class=\"h-full rounded-full\" style=\"width:88%;background:linear-gradient(90deg,#65f0b7,#62e6ff);\" data-kid=\"123\"></div>\n              </div>\n              <span class=\"text-xs font-bold\" style=\"color:#65f0b7;\" data-kid=\"124\">Alta</span>\n            </div>\n          </div>\n\n          \n          <div class=\"rounded-xl p-5\" style=\"background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.09);\" data-kid=\"125\">\n            <div class=\"flex items-center gap-3 mb-3\" data-kid=\"126\">\n              <div class=\"flex items-center justify-center w-8 h-8 rounded-lg\" style=\"background:rgba(98,230,255,0.12);border:1px solid rgba(98,230,255,0.2);\" data-kid=\"127\">\n                <i class=\"ti ti-shopping-cart\" style=\"color:#62e6ff;font-size:15px;\" data-kid=\"128\"></i>\n              </div>\n              <span class=\"text-sm font-semibold\" style=\"color:#f8fafc;\" data-kid=\"129\">Conversão</span>\n            </div>\n            <p class=\"text-xs mb-3\" style=\"color:#94a3b8;\" data-kid=\"130\">Taxa de visitantes que finalizam compra</p>\n            <div class=\"flex items-center gap-2\" data-kid=\"131\">\n              <div class=\"flex-1 h-1.5 rounded-full\" style=\"background:rgba(255,255,255,0.08);\" data-kid=\"132\">\n                <div class=\"h-full rounded-full\" style=\"width:70%;background:linear-gradient(90deg,#65f0b7,#62e6ff);\" data-kid=\"133\"></div>\n              </div>\n              <span class=\"text-xs font-bold\" style=\"color:#62e6ff;\" data-kid=\"134\">Média</span>\n            </div>\n          </div>\n\n          \n          <div class=\"rounded-xl p-5\" style=\"background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.09);\" data-kid=\"135\">\n            <div class=\"flex items-center gap-3 mb-3\" data-kid=\"136\">\n              <div class=\"flex items-center justify-center w-8 h-8 rounded-lg\" style=\"background:rgba(98,230,255,0.12);border:1px solid rgba(98,230,255,0.2);\" data-kid=\"137\">\n                <i class=\"ti ti-package\" style=\"color:#62e6ff;font-size:15px;\" data-kid=\"138\"></i>\n              </div>\n              <span class=\"text-sm font-semibold\" style=\"color:#f8fafc;\" data-kid=\"139\">Peso do Produto</span>\n            </div>\n            <p class=\"text-xs mb-3\" style=\"color:#94a3b8;\" data-kid=\"140\">Impacta diretamente no custo logístico</p>\n            <div class=\"flex items-center gap-2\" data-kid=\"141\">\n              <div class=\"flex-1 h-1.5 rounded-full\" style=\"background:rgba(255,255,255,0.08);\" data-kid=\"142\">\n                <div class=\"h-full rounded-full\" style=\"width:45%;background:linear-gradient(90deg,#f8b85c,#ef4444);\" data-kid=\"143\"></div>\n              </div>\n              <span class=\"text-xs font-bold\" style=\"color:#f8b85c;\" data-kid=\"144\">Média</span>\n            </div>\n          </div>\n\n          \n          <div class=\"rounded-xl p-5\" style=\"background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.09);\" data-kid=\"145\">\n            <div class=\"flex items-center gap-3 mb-3\" data-kid=\"146\">\n              <div class=\"flex items-center justify-center w-8 h-8 rounded-lg\" style=\"background:rgba(98,230,255,0.12);border:1px solid rgba(98,230,255,0.2);\" data-kid=\"147\">\n                <i class=\"ti ti-truck\" style=\"color:#62e6ff;font-size:15px;\" data-kid=\"148\"></i>\n              </div>\n              <span class=\"text-sm font-semibold\" style=\"color:#f8fafc;\" data-kid=\"149\">Custo de Frete</span>\n            </div>\n            <p class=\"text-xs mb-3\" style=\"color:#94a3b8;\" data-kid=\"150\">Custo médio de envio para o produto</p>\n            <div class=\"flex items-center gap-2\" data-kid=\"151\">\n              <div class=\"flex-1 h-1.5 rounded-full\" style=\"background:rgba(255,255,255,0.08);\" data-kid=\"152\">\n                <div class=\"h-full rounded-full\" style=\"width:50%;background:linear-gradient(90deg,#f8b85c,#ef4444);\" data-kid=\"153\"></div>\n              </div>\n              <span class=\"text-xs font-bold\" style=\"color:#f8b85c;\" data-kid=\"154\">Média</span>\n            </div>\n          </div>\n\n          \n          <div class=\"rounded-xl p-5\" style=\"background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.09);\" data-kid=\"155\">\n            <div class=\"flex items-center gap-3 mb-3\" data-kid=\"156\">\n              <div class=\"flex items-center justify-center w-8 h-8 rounded-lg\" style=\"background:rgba(98,230,255,0.12);border:1px solid rgba(98,230,255,0.2);\" data-kid=\"157\">\n                <i class=\"ti ti-star\" style=\"color:#62e6ff;font-size:15px;\" data-kid=\"158\"></i>\n              </div>\n              <span class=\"text-sm font-semibold\" style=\"color:#f8fafc;\" data-kid=\"159\">Avaliação Média</span>\n            </div>\n            <p class=\"text-xs mb-3\" style=\"color:#94a3b8;\" data-kid=\"160\">Nota média dos compradores (1 a 5)</p>\n            <div class=\"flex items-center gap-2\" data-kid=\"161\">\n              <div class=\"flex-1 h-1.5 rounded-full\" style=\"background:rgba(255,255,255,0.08);\" data-kid=\"162\">\n                <div class=\"h-full rounded-full\" style=\"width:65%;background:linear-gradient(90deg,#65f0b7,#62e6ff);\" data-kid=\"163\"></div>\n              </div>\n              <span class=\"text-xs font-bold\" style=\"color:#62e6ff;\" data-kid=\"164\">Média</span>\n            </div>\n          </div>\n\n          \n          <div class=\"rounded-xl p-5\" style=\"background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.09);\" data-kid=\"165\">\n            <div class=\"flex items-center gap-3 mb-3\" data-kid=\"166\">\n     