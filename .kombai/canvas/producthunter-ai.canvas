rgba(98,230,255,0.12);border:1px solid rgba(98,230,255,0.2);\" data-kid=\"197\">\n                <i class=\"ti ti-award\" style=\"color:#62e6ff;font-size:15px;\" data-kid=\"198\"></i>\n              </div>\n              <span class=\"text-sm font-semibold\" style=\"color:#f8fafc;\" data-kid=\"199\">Score de Reviews</span>\n            </div>\n            <p class=\"text-xs mb-3\" style=\"color:#94a3b8;\" data-kid=\"200\">Qualidade e quantidade de avaliações</p>\n            <div class=\"flex items-center gap-2\" data-kid=\"201\">\n              <div class=\"flex-1 h-1.5 rounded-full\" style=\"background:rgba(255,255,255,0.08);\" data-kid=\"202\">\n                <div class=\"h-full rounded-full\" style=\"width:72%;background:linear-gradient(90deg,#65f0b7,#62e6ff);\" data-kid=\"203\"></div>\n              </div>\n              <span class=\"text-xs font-bold\" style=\"color:#62e6ff;\" data-kid=\"204\">Média</span>\n            </div>\n          </div>\n\n          \n          <div class=\"rounded-xl p-5\" style=\"background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.09);\" data-kid=\"205\">\n            <div class=\"flex items-center gap-3 mb-3\" data-kid=\"206\">\n              <div class=\"flex items-center justify-center w-8 h-8 rounded-lg\" style=\"background:rgba(98,230,255,0.12);border:1px solid rgba(98,230,255,0.2);\" data-kid=\"207\">\n                <i class=\"ti ti-refresh\" style=\"color:#62e6ff;font-size:15px;\" data-kid=\"208\"></i>\n              </div>\n              <span class=\"text-sm font-semibold\" style=\"color:#f8fafc;\" data-kid=\"209\">Velocidade de Giro</span>\n            </div>\n            <p class=\"text-xs mb-3\" style=\"color:#94a3b8;\" data-kid=\"210\">Frequência de recompra e rotatividade</p>\n            <div class=\"flex items-center gap-2\" data-kid=\"211\">\n              <div class=\"flex-1 h-1.5 rounded-full\" style=\"background:rgba(255,255,255,0.08);\" data-kid=\"212\">\n                <div class=\"h-full rounded-full\" style=\"width:85%;background:linear-gradient(90deg,#65f0b7,#62e6ff);\" data-kid=\"213\"></div>\n              </div>\n              <span class=\"text-xs font-bold\" style=\"color:#65f0b7;\" data-kid=\"214\">Alta</span>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"rounded-2xl p-8\" style=\"background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.09);\" data-kid=\"215\">\n        <div class=\"flex items-center justify-between mb-7\" data-kid=\"216\">\n          <div data-kid=\"217\">\n            <h2 class=\"text-lg font-bold\" style=\"color:#f8fafc;\" data-kid=\"218\">Importância das Variáveis</h2>\n            <p class=\"text-sm\" style=\"color:#94a3b8;\" data-kid=\"219\">Quais variáveis mais impactam o Score de Oportunidade?</p>\n          </div>\n          <div class=\"flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-medium\" style=\"background:rgba(139,92,246,0.12);border:1px solid rgba(139,92,246,0.25);color:#8b5cf6;\" data-kid=\"220\">\n            <i class=\"ti ti-chart-bar\" style=\"font-size:12px;\" data-kid=\"221\"></i>\n            Feature Importance — Random Forest\n          </div>\n        </div>\n        <div style=\"height:280px;\" data-kid=\"222\">\n          <canvas id=\"featureImportanceChart\" data-kid=\"223\"></canvas>\n        </div>\n      </div>\n\n      \n      <div class=\"grid gap-6\" style=\"grid-template-columns:1fr 1fr;\" data-kid=\"224\">\n        \n        <div class=\"rounded-2xl p-7\" style=\"background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.09);\" data-kid=\"225\">\n          <div class=\"flex items-center gap-3 mb-6\" data-kid=\"226\">\n            <div class=\"flex items-center justify-center w-9 h-9 rounded-xl\" style=\"background:rgba(139,92,246,0.15);border:1px solid rgba(139,92,246,0.3);\" data-kid=\"227\">\n              <i class=\"ti ti-cpu\" style=\"color:#8b5cf6;font-size:18px;\" data-kid=\"228\"></i>\n            </div>\n            <div data-kid=\"229\">\n              <h3 class=\"text-base font-bold\" style=\"color:#f8fafc;\" data-kid=\"230\">Configuração do Modelo</h3>\n              <p class=\"text-xs\" style=\"color:#94a3b8;\" data-kid=\"231\">Arquitetura e parâmetros de treinamento</p>\n            </div>\n          </div>\n\n          <div class=\"flex flex-col gap-3\" data-kid=\"232\">\n            <div class=\"flex items-center justify-between py-3\" style=\"border-bottom:1px solid rgba(255,255,255,0.07);\" data-kid=\"233\">\n              <span class=\"text-sm\" style=\"color:#94a3b8;\" data-kid=\"234\">Algoritmo</span>\n              <span class=\"text-sm font-semibold font-mono\" style=\"color:#8b5cf6;\" data-kid=\"235\">Random Forest + XGBoost</span>\n            </div>\n            <div class=\"flex items-center justify-between py-3\" style=\"border-bottom:1px solid rgba(255,255,255,0.07);\" data-kid=\"236\">\n              <span class=\"text-sm\" style=\"color:#94a3b8;\" data-kid=\"237\">Features</span>\n              <span class=\"text-sm font-bold\" style=\"color:#62e6ff;\" data-kid=\"238\">12 variáveis</span>\n            </div>\n            <div class=\"flex items-center justify-between py-3\" style=\"border-bottom:1px solid rgba(255,255,255,0.07);\" data-kid=\"239\">\n              <span class=\"text-sm\" style=\"color:#94a3b8;\" data-kid=\"240\">Target</span>\n              <span class=\"text-sm font-semibold\" style=\"color:#f8fafc;\" data-kid=\"241\">Score de Oportunidade (0–100)</span>\n            </div>\n            <div class=\"flex items-center justify-between py-3\" style=\"border-bottom:1px solid rgba(255,255,255,0.07);\" data-kid=\"242\">\n              <span class=\"text-sm\" style=\"color:#94a3b8;\" data-kid=\"243\">Dataset de Treino</span>\n              <span class=\"text-sm font-semibold\" style=\"color:#65f0b7;\" data-kid=\"244\">1.200 produtos simulados</span>\n            </div>\n            <div class=\"flex items-center justify-between py-3\" style=\"border-bottom:1px solid rgba(255,255,255,0.07);\" data-kid=\"245\">\n              <span class=\"text-sm\" style=\"color:#94a3b8;\" data-kid=\"246\">Versão do Modelo</span>\n              <span class=\"text-sm font-mono font-bold\" style=\"color:#f8b85c;\" data-kid=\"247\">v2.3.1</span>\n            </div>\n            <div class=\"flex items-center justify-between py-3\" data-kid=\"248\">\n              <span class=\"text-sm\" style=\"color:#94a3b8;\" data-kid=\"249\">Último Treino</span>\n              <div class=\"flex items-center gap-2\" data-kid=\"250\">\n                <div class=\"w-1.5 h-1.5 rounded-full\" style=\"background:#65f0b7;box-shadow:0 0 5px #65f0b7;\" data-kid=\"251\"></div>\n                <span class=\"text-sm font-semibold\" style=\"color:#65f0b7;\" data-kid=\"252\">Hoje</span>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"rounded-2xl p-7\" style=\"background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.09);\" data-kid=\"253\">\n          <div class=\"flex items-center gap-3 mb-6\" data-kid=\"254\">\n            <div class=\"flex items-center justify-center w-9 h-9 rounded-xl\" style=\"background:rgba(101,240,183,0.12);border:1px solid rgba(101,240,183,0.3);\" data-kid=\"255\">\n              <i class=\"ti ti-chart-dots\" style=\"color:#65f0b7;font-size:18px;\" data-kid=\"256\"></i>\n            </div>\n            <div data-kid=\"257\">\n              <h3 class=\"text-base font-bold\" style=\"color:#f8fafc;\" data-kid=\"258\">Métricas de Performance</h3>\n              <p class=\"text-xs\" style=\"color:#94a3b8;\" data-kid=\"259\">Avaliação no conjunto de teste (20% dos dados)</p>\n            </div>\n          </div>\n\n          <div class=\"flex gap-6 items-start\" data-kid=\"260\">\n            <div class=\"flex flex-col gap-4 flex-1\" data-kid=\"261\">\n              \n              <div data-kid=\"262\">\n                <div class=\"flex items-center justify-between mb-1.5\" data-kid=\"263\">\n                  <span class=\"text-sm\" style=\"color:#94a3b8;\" data-kid=\"264\">Accuracy</span>\n                  <span class=\"text-sm font-bold font-mono\" style=\"color:#65f0b7;\" data-kid=\"265\">87.3%</span>\n                </div>\n                <div class=\"h-2 rounded-full\" style=\"background:rgba(255,255,255,0.08);\" data-kid=\"266\">\n                  <div class=\"h-full rounded-full\" style=\"width:87.3%;background:linear-gradient(90deg,#65f0b7,#22c55e);box-shadow:0 0 8px rgba(101,240,183,0.4);\" data-kid=\"267\"></div>\n                </div>\n              </div>\n              \n              <div data-kid=\"268\">\n                <div class=\"flex items-center justify-between mb-1.5\" data-kid=\"269\">\n                  <span class=\"text-sm\" style=\"color:#94a3b8;\" data-kid=\"270\">Precision</span>\n                  <span class=\"text-sm font-bold font-mono\" style=\"color:#62e6ff;\" data-kid=\"271\">84.1%</span>\n                </div>\n                <div class=\"h-2 rounded-full\" style=\"background:rgba(255,255,255,0.08);\" data-kid=\"272\">\n                  <div class=\"h-full rounded-full\" style=\"width:84.1%;background:linear-gradient(90deg,#62e6ff,#38bdf8);box-shadow:0 0 8px rgba(98,230,255,0.4);\" data-kid=\"273\"></div>\n                </div>\n              </div>\n              \n              <div data-kid=\"274\">\n                <div class=\"flex items-center justify-between mb-1.5\" data-kid=\"275\">\n                  <span class=\"text-sm\" style=\"color:#94a3b8;\" data-kid=\"276\">Recall</span>\n                  <span class=\"text-sm font-bold font-mono\" style=\"color:#8b5cf6;\" data-kid=\"277\">89.7%</span>\n                </div>\n                <div class=\"h-2 rounded-full\" style=\"background:rgba(255,255,255,0.08);\" data-kid=\"278\">\n                  <div class=\"h-full rounded-full\" style=\"width:89.7%;background:linear-gradient(90deg,#8b5cf6,#a78bfa);box-shadow:0 0 8px rgba(139,92,246,0.4);\" data-kid=\"279\"></div>\n                </div>\n              </div>\n              \n              <div data-kid=\"280\">\n                <div class=\"flex items-center justify-between mb-1.5\" data-kid=\"281\">\n                  <span class=\"text-sm\" style=\"color:#94a3b8;\" data-kid=\"282\">F1-Score</span>\n                  <span class=\"text-sm font-bold font-mono\" style=\"color:#65f0b7;\" data-kid=\"283\">86.8%</span>\n                </div>\n                <div class=\"h-2 rounded-full\" style=\"background:rgba(255,255,255,0.08);\" data-kid=\"284\">\n                  <div class=\"h-full rounded-full\" style=\"width:86.8%;background:linear-gradient(90deg,#65f0b7,#62e6ff);box-shadow:0 0 8px rgba(101,240,183,0.3);\" data-kid=\"285\"></div>\n                </div>\n              </div>\n            </div>\n            \n            <div style=\"width:160px;height:160px;flex-shrink:0;\" data-kid=\"286\">\n              <canvas id=\"performanceRadar\" data-kid=\"287\"></canvas>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"rounded-2xl p-8\" style=\"background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.09);\" data-kid=\"288\">\n        <div class=\"flex items-center gap-3 mb-8\" data-kid=\"289\">\n          <div class=\"flex items-center justify-center w-9 h-9 rounded-xl\" style=\"background:rgba(98,230,255,0.12);border:1px solid rgba(98,230,255,0.25);\" data-kid=\"290\">\n            <i class=\"ti ti-player-play\" style=\"color:#62e6ff;font-size:16px;\" data-kid=\"291\"></i>\n          </div>\n          <div data-kid=\"292\">\n            <h2 class=\"text-lg font-bold\" style=\"color:#f8fafc;\" data-kid=\"293\">Como o Score é Calculado?</h2>\n            <p class=\"text-sm\" style=\"color:#94a3b8;\" data-kid=\"294\">Exemplo passo a passo: Mini Impressora Térmica Portátil</p>\n          </div>\n          <div class=\"ml-auto px-3 py-1 rounded-full text-xs font-medium\" style=\"background:rgba(98,230,255,0.1);border:1px solid rgba(98,230,255,0.2);color:#62e6ff;\" data-kid=\"295\">\n            Exemplo real simulado\n          </div>\n        </div>\n\n        \n        <div class=\"flex items-start gap-3\" data-kid=\"296\">\n          \n          <div class=\"flex flex-col items-center flex-1\" data-kid=\"297\">\n            <div class=\"w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold mb-3\" style=\"background:rgba(98,230,255,0.15);border:1px solid rgba(98,230,255,0.4);color:#62e6ff;\" data-kid=\"298\">1</div>\n            <div class=\"rounded-xl p-5 w-full\" style=\"background:rgba(0,0,0,0.3);border:1px solid rgba(255,255,255,0.09);\" data-kid=\"299\">\n              <p class=\"text-xs font-semibold uppercase tracking-wider mb-3\" style=\"color:#62e6ff;\" data-kid=\"300\">Entradas Coletadas</p>\n              <div class=\"flex flex-col gap-1.5\" data-kid=\"301\">\n                <div class=\"flex justify-between\" data-kid=\"302\"><span class=\"text-xs\" style=\"color:#94a3b8;\" data-kid=\"303\">Margem</span><span class=\"text-xs font-mono font-bold\" style=\"color:#65f0b7;\" data-kid=\"304\">38%</span></div>\n                <div class=\"flex justify-between\" data-kid=\"305\"><span class=\"text-xs\" style=\"color:#94a3b8;\" data-kid=\"306\">Concorrência</span><span class=\"text-xs font-mono font-bold\" style=\"color:#62e6ff;\" data-kid=\"307\">42 sellers</span></div>\n                <div class=\"flex justify-between\" data-kid=\"308\"><span class=\"text-xs\" style=\"color:#94a3b8;\" data-kid=\"309\">Tendência</span><span class=\"text-xs font-mono font-bold\" style=\"color:#65f0b7;\" data-kid=\"310\">+47%</span></div>\n                <div class=\"flex justify-between\" data-kid=\"311\"><span class=\"text-xs\" style=\"color:#94a3b8;\" data-kid=\"312\">Conversão</span><span class=\"text-xs font-mono font-bold\" style=\"color:#62e6ff;\" data-kid=\"313\">4.2%</span></div>\n                <div class=\"flex justify-between\" data-kid=\"314\"><span class=\"text-xs\" style=\"color:#94a3b8;\" data-kid=\"315\">Peso</span><span class=\"text-xs font-mono\" style=\"color:#94a3b8;\" data-kid=\"316\">0.3kg</span></div>\n                <div class=\"flex justify-between\" data-kid=\"317\"><span class=\"text-xs\" style=\"color:#94a3b8;\" data-kid=\"318\">Reviews</span><span class=\"text-xs font-mono\" style=\"color:#94a3b8;\" data-kid=\"319\">4.7★</span></div>\n              </div>\n            </div>\n          </div>\n\n          \n          <div class=\"flex items-center justify-center mt-10\" style=\"width:32px;flex-shrink:0;\" data-kid=\"320\">\n            <i class=\"ti ti-arrow-right\" style=\"color:#62e6ff;font-size:20px;\" data-kid=\"321\"></i>\n          </div>\n\n          \n          <div class=\"flex flex-col items-center flex-1\" data-kid=\"322\">\n            <div class=\"w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold mb-3\" style=\"background:rgba(139,92,246,0.15);border:1px solid rgba(139,92,246,0.4);color:#8b5cf6;\" data-kid=\"323\">2</div>\n            <div class=\"rounded-xl p-5 w-full\" style=\"background:rgba(0,0,0,0.3);border:1px solid rgba(139,92,246,0.2);\" data-kid=\"324\">\n              <p class=\"text-xs font-semibold uppercase tracking-wider mb-3\" style=\"color:#8b5cf6;\" data-kid=\"325\">Modelo Processa</p>\n              <div class=\"flex flex-col gap-2\" data-kid=\"326\">\n                <div class=\"flex items-center gap-2\" data-kid=\"327\">\n                  <div class=\"w-2 h-2 rounded-full\" style=\"background:#8b5cf6;\" data-kid=\"328\"></div>\n                  <span class=\"text-xs\" style=\"color:#94a3b8;\" data-kid=\"329\">Normalização das features</span>\n                </div>\n                <div class=\"flex items-center gap-2\" data-kid=\"330\">\n                  <div class=\"w-2 h-2 rounded-full\" style=\"background:#8b5cf6;\" data-kid=\"331\"></div>\n                  <span class=\"text-xs\" style=\"color:#94a3b8;\" data-kid=\"332\">300 decision trees avaliadas</span>\n                </div>\n                <div class=\"flex items-center gap-2\" data-kid=\"333\">\n                  <div class=\"w-2 h-2 rounded-full\" style=\"background:#8b5cf6;\" data-kid=\"334\"></div>\n                  <span class=\"text-xs\" style=\"color:#94a3b8;\" data-kid=\"335\">XGBoost boost rounds: 150</span>\n                </div>\n                <div class=\"flex items-center gap-2\" data-kid=\"336\">\n                  <div class=\"w-2 h-2 rounded-full\" style=\"background:#8b5cf6;\" data-kid=\"337\"></div>\n                  <span class=\"text-xs\" style=\"color:#94a3b8;\" data-kid=\"338\">Ensemble voting final</span>\n                </div>\n                <div class=\"flex items-center gap-2\" data-kid=\"339\">\n                  <div class=\"w-2 h-2 rounded-full\" style=\"background:#8b5cf6;\" data-kid=\"340\"></div>\n                  <span class=\"text-xs\" style=\"color:#94a3b8;\" data-kid=\"341\">Score normalizado 0–100</span>\n                </div>\n                <div class=\"mt-2 p-2 rounded-lg text-center text-xs font-mono\" style=\"background:rgba(139,92,246,0.1);color:#8b5cf6;border:1px solid rgba(139,92,246,0.2);\" data-kid=\"342\">~12ms de inferência</div>\n              </div>\n            </div>\n          </div>\n\n          \n          <div class=\"flex items-center justify-center mt-10\" style=\"width:32px;flex-shrink:0;\" data-kid=\"343\">\n            <i class=\"ti ti-arrow-right\" style=\"color:#65f0b7;font-size:20px;\" data-kid=\"344\"></i>\n          </div>\n\n          \n          <div class=\"flex flex-col items-center flex-1\" data-kid=\"345\">\n            <div class=\"w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold mb-3\" style=\"background:rgba(101,240,183,0.15);border:1px solid rgba(101,240,183,0.4);color:#65f0b7;\" data-kid=\"346\">3</div>\n            <div class=\"rounded-xl p-5 w-full text-center\" style=\"background:rgba(0,0,0,0.3);border:1px solid rgba(101,240,183,0.2);\" data-kid=\"347\">\n              <p class=\"text-xs font-semibold uppercase tracking-wider mb-4\" style=\"color:#65f0b7;\" data-kid=\"348\">Score Calculado</p>\n              <div class=\"text-6xl font-black font-mono mb-1\" style=\"color:#65f0b7;text-shadow:0 0 30px rgba(101,240,183,0.4);\" data-kid=\"349\">87</div>\n              <div class=\"text-sm font-bold mb-3\" style=\"color:#65f0b7;\" data-kid=\"350\">/100</div>\n              <div class=\"px-3 py-1.5 rounded-full text-xs font-bold inline-block\" style=\"background:rgba(101,240,183,0.15);color:#65f0b7;border:1px solid rgba(101,240,183,0.3);\" data-kid=\"351\">\n                Alta Oportunidade\n              </div>\n              <p class=\"text-xs mt-3\" style=\"color:#94a3b8;\" data-kid=\"352\">Percentil 92 entre todos os produtos analisados</p>\n            </div>\n          </div>\n\n          \n          <div class=\"flex items-center justify-center mt-10\" style=\"width:32px;flex-shrink:0;\" data-kid=\"353\">\n            <i class=\"ti ti-arrow-right\" style=\"color:#62e6ff;font-size:20px;\" data-kid=\"354\"></i>\n          </div>\n\n          \n          <div class=\"flex flex-col items-center flex-1\" data-kid=\"355\">\n            <div class=\"w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold mb-3\" style=\"background:rgba(98,230,255,0.15);border:1px solid rgba(98,230,255,0.4);color:#62e6ff;\" data-kid=\"356\">4</div>\n            <div class=\"rounded-xl p-5 w-full\" style=\"background:rgba(0,0,0,0.3);border:1px solid rgba(98,230,255,0.15);\" data-kid=\"357\">\n              <p class=\"text-xs font-semibold uppercase tracking-wider mb-3\" style=\"color:#62e6ff;\" data-kid=\"358\">Ranking Gerado</p>\n              <div class=\"flex flex-col gap-2\" data-kid=\"359\">\n                <div class=\"flex items-center gap-2 py-1.5 px-2 rounded-lg\" style=\"background:rgba(101,240,183,0.08);border:1px solid rgba(101,240,183,0.2);\" data-kid=\"360\">\n                  <span class=\"text-xs font-bold w-4\" style=\"color:#65f0b7;\" data-kid=\"361\">#1</span>\n                  <span class=\"text-xs flex-1\" style=\"color:#f8fafc;\" data-kid=\"362\">Mini Impressora Térmica</span>\n                  <span class=\"text-xs font-mono font-bold\" style=\"color:#65f0b7;\" data-kid=\"363\">87</span>\n                </div>\n                <div class=\"flex items-center gap-2 py-1.5 px-2 rounded-lg\" data-kid=\"364\">\n                  <span class=\"text-xs font-bold w-4\" style=\"color:#94a3b8;\" data-kid=\"365\">#2</span>\n                  <span class=\"text-xs flex-1\" style=\"color:#94a3b8;\" data-kid=\"366\">Suporte Magnético</span>\n                  <span class=\"text-xs font-mono\" style=\"color:#94a3b8;\" data-kid=\"367\">79</span>\n                </div>\n                <div class=\"flex items-center gap-2 py-1.5 px-2 rounded-lg\" data-kid=\"368\">\n                  <span class=\"text-xs font-bold w-4\" style=\"color:#94a3b8;\" data-kid=\"369\">#3</span>\n                  <span class=\"text-xs flex-1\" style=\"color:#94a3b8;\" data-kid=\"370\">Luminária Gamer</span>\n                  <span class=\"text-xs font-mono\" style=\"color:#94a3b8;\" data-kid=\"371\">71</span>\n                </div>\n                <div class=\"flex items-center gap-2 py-1.5 px-2 rounded-lg\" data-kid=\"372\">\n                  <span class=\"text-xs font-bold w-4\" style=\"color:#94a3b8;\" data-kid=\"373\">#4</span>\n                  <span class=\"text-xs flex-1\" style=\"color:#94a3b8;\" data-kid=\"374\">Cabo Retráctil USB-C</span>\n                  <span class=\"text-xs font-mono\" style=\"color:#94a3b8;\" data-kid=\"375\">65</span>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"rounded-2xl p-8 relative overflow-hidden\" style=\"background:linear-gradient(135deg,rgba(139,92,246,0.12) 0%,rgba(98,230,255,0.06) 100%);border:1px solid rgba(139,92,246,0.25);\" data-kid=\"376\">\n        <div class=\"absolute top-0 right-0 w-64 h-64 pointer-events-none\" style=\"background:radial-gradient(circle,rgba(139,92,246,0.15) 0%,transparent 70%);\" data-kid=\"377\"></div>\n        <div class=\"relative\" data-kid=\"378\">\n          <div class=\"flex items-start justify-between mb-6\" data-kid=\"379\">\n            <div data-kid=\"380\">\n              <div class=\"flex items-center gap-2 mb-2\" data-kid=\"381\">\n                <i class=\"ti ti-rocket\" style=\"color:#8b5cf6;font-size:18px;\" data-kid=\"382\"></i>\n                <span class=\"text-xs font-bold uppercase tracking-widest\" style=\"color:#8b5cf6;\" data-kid=\"383\">Roadmap</span>\n              </div>\n              <h2 class=\"text-xl font-bold mb-2\" style=\"color:#f8fafc;\" data-kid=\"384\">Próximos Passos</h2>\n              <p class=\"text-sm max-w-lg\" style=\"color:#94a3b8;\" data-kid=\"385\">Este modelo será conectado a APIs oficiais de marketplaces para dados em tempo real, elevando a precisão das recomendações para o próximo nível.</p>\n            </div>\n          </div>\n\n          <div class=\"flex items-center gap-4 mb-8\" data-kid=\"386\">\n            <div class=\"px-4 py-2 rounded-xl flex items-center gap-2 text-sm font-semibold\" style=\"background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.14);color:#f8fafc;\" data-kid=\"387\">\n              <i class=\"ti ti-api\" style=\"color:#f8b85c;font-size:14px;\" data-kid=\"388\"></i>\n              Mercado Livre API\n            </div>\n            <div class=\"px-4 py-2 rounded-xl flex items-center gap-2 text-sm font-semibold\" style=\"background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.14);color:#f8fafc;\" data-kid=\"389\">\n              <i class=\"ti ti-api\" style=\"color:#62e6ff;font-size:14px;\" data-kid=\"390\"></i>\n              Shopee OpenAPI\n            </div>\n            <div class=\"px-4 py-2 rounded-xl flex items-center gap-2 text-sm font-semibold\" style=\"background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.14);color:#f8fafc;\" data-kid=\"391\">\n              <i class=\"ti ti-api\" style=\"color:#65f0b7;font-size:14px;\" data-kid=\"392\"></i>\n              Amazon MWS\n            </div>\n          </div>\n\n          <div class=\"flex items-center gap-4\" data-kid=\"393\">\n            <button class=\"flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold\" style=\"background:rgba(139,92,246,0.2);border:1px solid rgba(139,92,246,0.4);color:#a78bfa;cursor:pointer;\" data-kid=\"394\">\n              <i class=\"ti ti-database-plus\" style=\"font-size:14px;\" data-kid=\"395\"></i>\n              Contribuir com Dados Reais\n            </button>\n            <button class=\"flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold\" style=\"background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.12);color:#94a3b8;cursor:pointer;\" data-kid=\"396\">\n              <i class=\"ti ti-book\" style=\"font-size:14px;\" data-kid=\"397\"></i>\n              Documentação Técnica\n            </button>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"h-8\" data-kid=\"398\"></div>\n    </div>\n  </div>\n</div>\n\n<script data-kid=\"399\">\n(function() {\n  // Feature Importance Chart\n  const fiCtx = document.getElementById('featureImportanceChart');\n  if (fiCtx) {\n    new Chart(fiCtx, {\n      type: 'bar',\n      data: {\n        labels: ['Margem Bruta', 'Tend. de Demanda', 'Concorrência', 'Taxa de Conversão', 'Vol. de Vendas', 'Custo de Frete', 'Peso do Produto', 'Sazonalidade'],\n        datasets: [{\n          label: 'Importância (%)',\n          data: [28, 22, 18, 15, 9, 8, 5, 4],\n          backgroundColor: [\n            'rgba(101,240,183,0.75)',\n            'rgba(98,230,255,0.75)',\n            'rgba(139,92,246,0.75)',\n            'rgba(98,200,255,0.65)',\n            'rgba(101,240,183,0.5)',\n            'rgba(248,184,92,0.65)',\n            'rgba(248,184,92,0.5)',\n            'rgba(148,163,184,0.5)'\n          ],\n          borderColor: [\n            '#65f0b7','#62e6ff','#8b5cf6','#62e6ff',\n            '#65f0b7','#f8b85c','#f8b85c','#64748b'\n          ],\n          borderWidth: 1,\n          borderRadius: 6,\n          borderSkipped: false\n        }]\n      },\n      options: {\n        indexAxis: 'y',\n        responsive: true,\n        maintainAspectRatio: false,\n        plugins: {\n          legend: { display: false },\n          tooltip: {\n            backgroundColor: 'rgba(16,20,27,0.95)',\n            borderColor: 'rgba(255,255,255,0.12)',\n            borderWidth: 1,\n            titleColor: '#f8fafc',\n            bodyColor: '#94a3b8',\n            callbacks: {\n              label: function(context) { return ' ' + context.parsed.x + '% de importância'; }\n            }\n          }\n        },\n        scales: {\n          x: {\n            grid: { color: 'rgba(255,255,255,0.05)', drawBorder: false },\n            ticks: { color: '#64748b', font: { size: 11 }, callback: v => v + '%' },\n            border: { display: false }\n          },\n          y: {\n            grid: { display: false },\n            ticks: { color: '#94a3b8', font: { size: 12, weight: '500' } },\n            border: { display: false }\n          }\n        }\n      }\n    });\n  }\n\n  // Performance Radar\n  const prCtx = document.getElementById('performanceRadar');\n  if (prCtx) {\n    new Chart(prCtx, {\n      type: 'radar',\n      data: {\n        labels: ['Accuracy', 'Precision', 'Recall', 'F1', 'AUC'],\n        datasets: [{\n          label: 'Modelo',\n          data: [87.3, 84.1, 89.7, 86.8, 91.2],\n          backgroundColor: 'rgba(101,240,183,0.12)',\n          borderColor: '#65f0b7',\n          borderWidth: 2,\n          pointBackgroundColor: '#65f0b7',\n          pointBorderColor: '#07090d',\n          pointRadius: 3\n        }]\n      },\n      options: {\n        responsive: true,\n        maintainAspectRatio: true,\n        plugins: { legend: { display: false } },\n        scales: {\n          r: {\n            min: 70, max: 100,\n            grid: { color: 'rgba(255,255,255,0.08)' },\n            angleLines: { color: 'rgba(255,255,255,0.06)' },\n            ticks: { display: false },\n            pointLabels: { color: '#64748b', font: { size: 9 } }\n          }\n        }\n      }\n    });\n  }\n})();\n</script>\n",
